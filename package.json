    "Mohit Vashishtha"
  ],
  "license": "ISC",
  "bin": {
    "agility-cli": "dist/index.js",
    "agility": "dist/index.js"
  },
  "overrides": {
    "rxjs": "^7.8.2"
  },
  "dependencies": {
    "@agility/content-fetch": "^2.0.10",
    "@agility/content-sync": "^1.2.0",
    "@agility/management-sdk": "^0.1.35",
    "ansi-colors": "^4.1.3",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "cli-progress": "^3.11.2",
