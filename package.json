    "inquirer-search-list": "^1.2.6",
    "keytar": "^7.9.0",
    "log-update": "^5.0.1",
    "open": "^8.4.0",
    "ora": "^5.4.1",
    "tsconfig-paths": "^4.2.0",
    "wrap-ansi": "^9.0.0",
    "yargs": "^17.6.2"
  },
  "devDependencies": {
    "@types/form-data": "^2.2.1",
    "@types/inquirer": "^9.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.11.17",
    "@types/yargs": "^17.0.17",
    "jest": "^29.7.0",
