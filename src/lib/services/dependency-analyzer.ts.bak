import * as mgmtApi from '@agility/management-sdk';
import ansiColors from 'ansi-colors';

// Core Types for Dependency Analysis
export type EntityType = 'gallery' | 'asset' | 'model' | 'container' | 'content' | 'template' | 'page';
export type EntityKey = `${EntityType}:${string | number}`;

export interface EntityNode {
    key: EntityKey;
    type: EntityType;
    sourceData: any;
    dependencies: EntityKey[];
    dependents: EntityKey[];
    creationStatus: 'pending' | 'created' | 'failed' | 'stub';
    targetId?: string | number;
    priority: number; // For processing order
}

export interface UniversalDependencyGraph {
    entities: Map<EntityKey, EntityNode>;
    relationships: RelationshipEdge[];
    cycles: DependencyCycle[];
    processingOrder: EntityKey[];
    usedAssets: Set<string>; // URLs of assets that are actually referenced
}

export interface RelationshipEdge {
    from: EntityKey;
    to: EntityKey;
    relationship: RelationshipType;
    isRequired: boolean;
    fieldPath: string;
    resolutionStrategy: ResolutionStrategy;
}

export enum RelationshipType {
    // Intra-entity relationships
    MODEL_TO_MODEL = 'model→model',
    CONTENT_TO_CONTENT = 'content→content',
    PAGE_TO_PAGE = 'page→page',
    
    // Cross-entity relationships
    GALLERY_TO_ASSET = 'gallery→asset',
    MODEL_TO_CONTAINER = 'model→container',
    CONTAINER_TO_MODEL = 'container→model',
    MODEL_TO_CONTENT = 'model→content',
    CONTAINER_TO_TEMPLATE = 'container→template',
    MODEL_TO_TEMPLATE = 'model→template',
    TEMPLATE_TO_PAGE = 'template→page',
    ASSET_TO_CONTENT = 'asset→content',
    CONTENT_TO_ASSET = 'content→asset',
    CONTENT_TO_PAGE = 'content→page',
    CONTAINER_TO_CONTENT = 'container→content'
}

export enum ResolutionStrategy {
    REQUIRED_FORWARD = 'required_forward',
    CIRCULAR_STUB = 'circular_stub',
    DEFERRED_LINK = 'deferred_link',
    OPTIONAL_LINK = 'optional_link',
    BREAK_CYCLE = 'break_cycle'
}

export interface DependencyCycle {
    entities: EntityKey[];
    relationships: RelationshipType[];
    cycleLength: number;
    severity: 'simple' | 'complex' | 'cross_entity';
    isBreakable: boolean;
    breakPoints: EntityKey[];
}

export interface EntityDependency {
    sourceEntity: EntityKey;
    targetEntity: EntityKey;
    relationship: RelationshipType;
    isRequired: boolean;
    fieldPath: string;
    resolutionStrategy: ResolutionStrategy;
}

export interface AssetReference {
    sourceUrl: string;
    contentId: number;
    fieldPath: string;
    isRequired: boolean;
    usage: 'direct' | 'gallery' | 'nested';
}

export interface UsedAssetReport {
    totalAssets: number;
    usedAssets: AssetReference[];
    unusedAssets: string[];
    assetsByContent: Map<number, AssetReference[]>;
    galleryUsage: Map<number, number>;
    optimizationPotential: {
        assetsToSkip: number;
        sizeReduction: string;
        migrationSpeedup: string;
    };
}

export interface DependencyChainAnalysis {
    contentChains: DependencyChain[];
    pageChains: DependencyChain[];
    cycles: DependencyCycle[];
    nonDependentItems: {
        galleries: any[];
        assets: any[];
        models: any[];
        containers: any[];
        content: any[];
        templates: any[];
        pages: any[];
    };
    chainStats: {
        totalChains: number;
        totalCycles: number;
        longestChain: number;
        avgChainLength: number;
    };
    entityCounts: {
        total: {
            galleries: number;
            assets: number;
            models: number;
            containers: number;
            content: number;
            templates: number;
            pages: number;
        };
        inChains: {
            galleries: number;
            assets: number;
            models: number;
            containers: number;
            content: number;
            templates: number;
            pages: number;
        };
        nonDependent: {
            galleries: number;
            assets: number;
            models: number;
            containers: number;
            content: number;
            templates: number;
            pages: number;
        };
        inCycles: {
            galleries: number;
            assets: number;
            models: number;
            containers: number;
            content: number;
            templates: number;
            pages: number;
        };
    };
}

export interface DependencyChain {
    rootEntity: EntityKey;
    rootType: EntityType;
    dependencies: DependencyNode[];
    totalDepth: number;
}

export interface DependencyNode {
    entity: EntityKey;
    relationship: RelationshipType;
    isRequired: boolean;
    fieldPath: string;
    depth: number;
    children: DependencyNode[];
}

export interface ExecutionChainAnalysis {
    completeChains: ExecutionChain[];
    brokenChains: ExecutionChain[];
    standaloneItems: {
        content: mgmtApi.ContentItem[];
        pages: mgmtApi.PageItem[];
    };
    summary: {
        totalExecutableChains: number;
        totalBrokenChains: number;
        totalStandaloneItems: number;
        parallelExecutionGroups: number;
    };
}

export interface ExecutionChain {
    entryPoint: EntityKey;
    entryType: 'page' | 'content';
    dependencies: DependencyNode[];
    isComplete: boolean;
    missingDependencies: string[];
    depth: number;
}

// Utility Functions
export function createEntityKey(type: EntityType, identifier: string | number): EntityKey {
    return `${type}:${identifier}`;
}

export function parseEntityKey(key: EntityKey): { type: EntityType; id: string | number } {
    const [type, id] = key.split(':');
    return { 
        type: type as EntityType, 
        id: isNaN(Number(id)) ? id : Number(id) 
    };
}

/**
 * Universal Dependency Analyzer
 * 
 * This is the core component that analyzes dependencies across all entity types,
 * builds the complete dependency graph, and determines optimal processing order.
 */
export class DependencyAnalyzer {
    private debug: boolean = false;

    constructor(debug: boolean = false) {
        this.debug = debug;
    }

    /**
     * Main entry point: Analyze all entities and build complete dependency graph
     */
    async analyzeDependencies(entities: {
        galleries?: mgmtApi.assetGalleries[];
        assets?: mgmtApi.Media[];
        models?: mgmtApi.Model[];
        containers?: mgmtApi.Container[];
        content?: mgmtApi.ContentItem[];
        templates?: mgmtApi.PageModel[];
        pages?: mgmtApi.PageItem[];
    }, options: {
        onlyUsedAssets?: boolean;
        assetAnalysisDepth?: 'shallow' | 'deep';
    } = {}): Promise<UniversalDependencyGraph> {
        
        const graph: UniversalDependencyGraph = {
            entities: new Map(),
            relationships: [],
            cycles: [],
            processingOrder: [],
            usedAssets: new Set()
        };

        // Step 1: Analyze used assets first (if enabled)
        if (options.onlyUsedAssets && entities.content) {
            const usedAssetReport = this.analyzeUsedAssets(entities.content);
            usedAssetReport.usedAssets.forEach(ref => graph.usedAssets.add(ref.sourceUrl));
            
            if (this.debug) {
                console.log(ansiColors.yellow(`[Dependency Analyzer] Found ${usedAssetReport.usedAssets.length} used assets out of ${entities.assets?.length || 0} total`));
            }
        }

        // Step 2: Add all entities to graph
        await this.addEntitiesToGraph(entities, graph, options);

        // Step 3: Analyze dependencies for each entity type
        await this.analyzeDependenciesByType(entities, graph);

        // Step 4: Detect cycles
        graph.cycles = this.detectCycles(graph);

        // Step 5: Generate processing order
        graph.processingOrder = this.generateProcessingOrder(graph);

        // Step 6: Report analysis results
        this.reportAnalysisResults(graph);

        return graph;
    }

    /**
     * Normalize asset URLs to handle different CDN patterns
     */
    private normalizeAssetUrl(url: string): string {
        if (!url || typeof url !== 'string') return url;
        
        // Normalize different Agility CDN patterns to consistent format
        return url
            .replace('https://cdn.aglty.io/', 'https://origin.agilitycms.com/')
            .replace('http://cdn.aglty.io/', 'https://origin.agilitycms.com/')
            .replace('http://origin.agilitycms.com/', 'https://origin.agilitycms.com/');
    }

    /**
     * Add entities to the dependency graph with proper metadata
     */
    private async addEntitiesToGraph(entities: any, graph: UniversalDependencyGraph, options: any): Promise<void> {
        const { onlyUsedAssets } = options;
        
        // Create URL-to-mediaID mapping for consistent asset entity keys
        const assetUrlToIdMap = new Map<string, number>();
        if (entities.assets) {
            entities.assets.forEach((asset: any) => {
                if (asset.originUrl) {
                    const normalizedUrl = this.normalizeAssetUrl(asset.originUrl);
                    assetUrlToIdMap.set(normalizedUrl, asset.mediaID);
                    
                    // Also map the original URL if different
                    if (normalizedUrl !== asset.originUrl) {
                        assetUrlToIdMap.set(asset.originUrl, asset.mediaID);
                    }
                }
            });
        }

        // Add galleries
        if (entities.galleries) {
            entities.galleries.forEach((gallery: any) => {
                const galleryId = gallery.assetMediaGroupings?.[0]?.mediaGroupingID || gallery.galleryID || gallery.id || `gallery-${Math.random()}`;
                const entityKey = createEntityKey('gallery', galleryId);
                graph.entities.set(entityKey, {
                    key: entityKey,
                    type: 'gallery',
                    sourceData: gallery,
                    dependencies: [],
                    dependents: [],
                    creationStatus: 'pending',
                    priority: 1
                });
            });
        }

        // Add assets
        if (entities.assets) {
            entities.assets.forEach((asset: mgmtApi.Media) => {
                // Create asset entity with mediaID as primary key
                const primaryKey = createEntityKey('asset', asset.mediaID);
                graph.entities.set(primaryKey, {
                    key: primaryKey,
                    type: 'asset',
                    sourceData: asset,
                    dependencies: [],
                    dependents: [],
                    creationStatus: 'pending',
                    priority: 2
                });
                
                // Create asset entities with normalized URLs for content→asset references
                if (asset.originUrl) {
                    const normalizedUrl = this.normalizeAssetUrl(asset.originUrl);
                    const urlKey = createEntityKey('asset', normalizedUrl);
                    graph.entities.set(urlKey, {
                        key: urlKey,
                        type: 'asset',
                        sourceData: asset, // Same asset data
                        dependencies: [],
                        dependents: [],
                        creationStatus: 'pending',
                        priority: 2
                    });
                    
                    // Also create with original URL if different from normalized
                    if (normalizedUrl !== asset.originUrl) {
                        const originalUrlKey = createEntityKey('asset', asset.originUrl);
                        graph.entities.set(originalUrlKey, {
                            key: originalUrlKey,
                            type: 'asset',
                            sourceData: asset,
                            dependencies: [],
                            dependents: [],
                            creationStatus: 'pending',
                            priority: 2
                        });
                    }
                }
            });
        }

        // Add models
        if (entities.models) {
            entities.models.forEach((model: mgmtApi.Model) => {
                const entityKey = createEntityKey('model', model.referenceName);
                graph.entities.set(entityKey, {
                    key: entityKey,
                    type: 'model',
                    sourceData: model,
                    dependencies: [],
                    dependents: [],
                    creationStatus: 'pending',
                    priority: 3
                });
            });
        }

        // Add containers
        if (entities.containers) {
            entities.containers.forEach((container: mgmtApi.Container) => {
                const entityKey = createEntityKey('container', container.contentViewID);
                graph.entities.set(entityKey, {
                    key: entityKey,
                    type: 'container',
                    sourceData: container,
                    dependencies: [],
                    dependents: [],
                    creationStatus: 'pending',
                    priority: 4
                });
            });
        }

        // Add content
        if (entities.content) {
            entities.content.forEach((content: mgmtApi.ContentItem) => {
                const entityKey = createEntityKey('content', content.contentID);
                graph.entities.set(entityKey, {
                    key: entityKey,
                    type: 'content',
                    sourceData: content,
                    dependencies: [],
                    dependents: [],
                    creationStatus: 'pending',
                    priority: 5
                });
            });
        }

        // Add templates
        if (entities.templates) {
            entities.templates.forEach((template: mgmtApi.PageModel) => {
                const entityKey = createEntityKey('template', template.pageTemplateName);
                graph.entities.set(entityKey, {
                    key: entityKey,
                    type: 'template',
                    sourceData: template,
                    dependencies: [],
                    dependents: [],
                    creationStatus: 'pending',
                    priority: 6
                });
            });
        }

        // Add pages
        if (entities.pages) {
            entities.pages.forEach((page: mgmtApi.PageItem) => {
                const entityKey = createEntityKey('page', page.pageID);
                graph.entities.set(entityKey, {
                    key: entityKey,
                    type: 'page',
                    sourceData: page,
                    dependencies: [],
                    dependents: [],
                    creationStatus: 'pending',
                    priority: 7
                });
            });
        }

        if (this.debug) {
            console.log(`[Graph Building] Added ${graph.entities.size} entities to dependency graph`);
            console.log(`[Graph Building] Asset URL mappings: ${assetUrlToIdMap.size}`);
        }
    }

    /**
     * Analyze dependencies for each entity type
     */
    private async analyzeDependenciesByType(entities: any, graph: UniversalDependencyGraph): Promise<void> {
        // Create URL-to-mediaID mapping for consistent asset entity keys
        const assetUrlToIdMap = new Map<string, number>();
        if (entities.assets) {
            entities.assets.forEach((asset: any) => {
                if (asset.originUrl) {
                    assetUrlToIdMap.set(asset.originUrl, asset.mediaID);
                }
            });
        }

        // Analyze model dependencies
        if (entities.models) {
            for (const model of entities.models) {
                const dependencies = this.analyzeModelDependencies(model);
                this.addDependenciesToGraph(dependencies, graph);
            }
        }

        // Analyze container dependencies
        if (entities.containers) {
            for (const container of entities.containers) {
                const dependencies = this.analyzeContainerDependencies(container, entities);
                this.addDependenciesToGraph(dependencies, graph);
            }
        }

        // Analyze content dependencies
        if (entities.content) {
            for (const contentItem of entities.content) {
                const dependencies = this.analyzeContentDependencies(contentItem, graph.usedAssets, assetUrlToIdMap);
                this.addDependenciesToGraph(dependencies, graph);
            }
        }

        // Analyze template dependencies
        if (entities.templates) {
            for (const template of entities.templates) {
                const dependencies = this.analyzeTemplateDependencies(template);
                this.addDependenciesToGraph(dependencies, graph);
            }
        }

        // Analyze page dependencies
        if (entities.pages) {
            for (const page of entities.pages) {
                const dependencies = this.analyzePageDependencies(page);
                this.addDependenciesToGraph(dependencies, graph);
            }
        }

        // Analyze asset dependencies
        if (entities.assets) {
            for (const asset of entities.assets) {
                if (!graph.usedAssets.size || graph.usedAssets.has(asset.originUrl)) {
                    const dependencies = this.analyzeAssetDependencies(asset);
                    this.addDependenciesToGraph(dependencies, graph);
                }
            }
        }
    }

    /**
     * Analyze model dependencies (Model → Model via field references)
     */
    analyzeModelDependencies(model: mgmtApi.Model): EntityDependency[] {
        const dependencies: EntityDependency[] = [];
        
        model.fields?.forEach((field, index) => {
            if (field.type === 'Content' && field.settings?.['ContentDefinition']) {
                const referencedModel = field.settings['ContentDefinition'];
                dependencies.push({
                    sourceEntity: createEntityKey('model', model.referenceName),
                    targetEntity: createEntityKey('model', referencedModel),
                    relationship: RelationshipType.MODEL_TO_MODEL,
                    isRequired: true,
                    fieldPath: `fields[${index}].settings.ContentDefinition`,
                    resolutionStrategy: ResolutionStrategy.CIRCULAR_STUB
                });
            }
        });
        
        return dependencies;
    }

    /**
     * Analyze container dependencies (Container → Model)
     */
    analyzeContainerDependencies(container: mgmtApi.Container, entities?: any): EntityDependency[] {
        const dependencies: EntityDependency[] = [];
        
        if (container.contentDefinitionID) {
            // Find the model referenceName for this contentDefinitionID
            let modelKey = container.contentDefinitionID.toString();
            
            // If we have access to the models, try to find the correct referenceName
            if (entities?.models) {
                const model = entities.models.find((m: any) => m.id === container.contentDefinitionID);
                if (model && model.referenceName) {
                    modelKey = model.referenceName;
                }
            }
            
            dependencies.push({
                sourceEntity: createEntityKey('container', container.contentViewID),
                targetEntity: createEntityKey('model', modelKey),
                relationship: RelationshipType.CONTAINER_TO_MODEL,
                isRequired: true,
                fieldPath: 'contentDefinitionID',
                resolutionStrategy: ResolutionStrategy.REQUIRED_FORWARD
            });
        }
        
        return dependencies;
    }

    /**
     * Analyze content dependencies (Content → Model, Content → Content, Content → Asset)
     */
    analyzeContentDependencies(content: mgmtApi.ContentItem, usedAssets: Set<string>, assetUrlToIdMap?: Map<string, number>): EntityDependency[] {
        const dependencies: EntityDependency[] = [];
        
        // 1. Content → Model dependency
        if (content.properties?.definitionName) {
            dependencies.push({
                sourceEntity: createEntityKey('content', content.contentID),
                targetEntity: createEntityKey('model', content.properties.definitionName),
                relationship: RelationshipType.MODEL_TO_CONTENT,
                isRequired: true,
                fieldPath: 'properties.definitionName',
                resolutionStrategy: ResolutionStrategy.REQUIRED_FORWARD
            });
        }

        // 2. Content → Content dependencies (nested content references)
        if (content.fields) {
            const nestedContentRefs = this.extractNestedContentReferences(content.fields);
            nestedContentRefs.forEach(ref => {
                dependencies.push({
                    sourceEntity: createEntityKey('content', content.contentID),
                    targetEntity: createEntityKey('content', ref.contentID),
                    relationship: RelationshipType.CONTENT_TO_CONTENT,
                    isRequired: ref.isRequired,
                    fieldPath: ref.fieldPath,
                    resolutionStrategy: ResolutionStrategy.DEFERRED_LINK
                });
            });
        }

        // 3. Content → Asset dependencies (use consistent mediaID if mapping available)
        if (content.fields) {
            const assetDeps = this.extractAssetReferences(content.fields, content.contentID);
            
            assetDeps.forEach(dep => {
                if (!usedAssets.size || usedAssets.has(dep.sourceUrl)) {
                    // Use mediaID if mapping is available, otherwise use URL
                    const assetId = assetUrlToIdMap?.get(dep.sourceUrl) || dep.sourceUrl;
                    
                    const assetDependency = {
                        sourceEntity: createEntityKey('content', content.contentID),
                        targetEntity: createEntityKey('asset', assetId),
                        relationship: RelationshipType.CONTENT_TO_ASSET,
                        isRequired: false,
                        fieldPath: dep.fieldPath,
                        resolutionStrategy: ResolutionStrategy.OPTIONAL_LINK
                    };
                    
                    dependencies.push(assetDependency);
                }
            });
        }

        return dependencies;
    }

    /**
     * Analyze template dependencies (Template → Model, Template → Container)
     */
    analyzeTemplateDependencies(template: mgmtApi.PageModel): EntityDependency[] {
        const dependencies: EntityDependency[] = [];
        
        template.contentSectionDefinitions?.forEach((section, index) => {
            // Template → Model dependency
            if (section.contentDefinitionID) {
                dependencies.push({
                    sourceEntity: createEntityKey('template', template.pageTemplateName),
                    targetEntity: createEntityKey('model', `MODEL_ID_${section.contentDefinitionID}`),
                    relationship: RelationshipType.MODEL_TO_TEMPLATE,
                    isRequired: true,
                    fieldPath: `contentSectionDefinitions[${index}].contentDefinitionID`,
                    resolutionStrategy: ResolutionStrategy.REQUIRED_FORWARD
                });
            }
            
            // Template → Container dependency
            if (section.itemContainerID) {
                dependencies.push({
                    sourceEntity: createEntityKey('template', template.pageTemplateName),
                    targetEntity: createEntityKey('container', section.itemContainerID),
                    relationship: RelationshipType.CONTAINER_TO_TEMPLATE,
                    isRequired: true,
                    fieldPath: `contentSectionDefinitions[${index}].itemContainerID`,
                    resolutionStrategy: ResolutionStrategy.REQUIRED_FORWARD
                });
            }
        });
        
        return dependencies;
    }

    /**
     * Analyze page dependencies (Page → Template, Page → Content, Page → Page)
     */
    analyzePageDependencies(page: mgmtApi.PageItem): EntityDependency[] {
        const dependencies: EntityDependency[] = [];
        
        // 1. Page → Template dependency (unless it's a folder page)
        if (page.templateName && page.pageType !== 'folder') {
            dependencies.push({
                sourceEntity: createEntityKey('page', page.pageID),
                targetEntity: createEntityKey('template', page.templateName),
                relationship: RelationshipType.TEMPLATE_TO_PAGE,
                isRequired: true,
                fieldPath: 'templateName',
                resolutionStrategy: ResolutionStrategy.REQUIRED_FORWARD
            });
        }
        
        // 2. Page → Parent Page dependency
        if (page.parentPageID && page.parentPageID > 0) {
            dependencies.push({
                sourceEntity: createEntityKey('page', page.pageID),
                targetEntity: createEntityKey('page', page.parentPageID),
                relationship: RelationshipType.PAGE_TO_PAGE,
                isRequired: true,
                fieldPath: 'parentPageID',
                resolutionStrategy: ResolutionStrategy.REQUIRED_FORWARD
            });
        }
        
        // 3. Page → Content dependencies (zones)
        const zoneDeps = this.extractPageZoneContentReferences(page.zones);
        zoneDeps.forEach(dep => {
            dependencies.push({
                sourceEntity: createEntityKey('page', page.pageID),
                targetEntity: createEntityKey('content', dep.contentID),
                relationship: RelationshipType.CONTENT_TO_PAGE,
                isRequired: false, // Page can exist without content
                fieldPath: dep.fieldPath,
                resolutionStrategy: ResolutionStrategy.DEFERRED_LINK
            });
        });
        
        return dependencies;
    }

    /**
     * Analyze asset dependencies (Asset → Gallery)
     */
    analyzeAssetDependencies(asset: mgmtApi.Media): EntityDependency[] {
        const dependencies: EntityDependency[] = [];
        
        if (asset.mediaGroupingID) {
            dependencies.push({
                sourceEntity: createEntityKey('asset', asset.mediaID),
                targetEntity: createEntityKey('gallery', asset.mediaGroupingID),
                relationship: RelationshipType.GALLERY_TO_ASSET,
                isRequired: false, // Asset can exist without gallery
                fieldPath: 'mediaGroupingID',
                resolutionStrategy: ResolutionStrategy.OPTIONAL_LINK
            });
        }
        
        return dependencies;
    }

    /**
     * Analyze which assets are actually used by content items
     */
    analyzeUsedAssets(contentItems: mgmtApi.ContentItem[]): UsedAssetReport {
        const usedAssets: AssetReference[] = [];
        const assetsByContent = new Map<number, AssetReference[]>();
        const galleryUsage = new Map<number, number>();
        
        for (const content of contentItems) {
            const contentAssets: AssetReference[] = [];
            const assetRefs = this.extractAssetReferences(content.fields, content.contentID);
            
            assetRefs.forEach(ref => {
                usedAssets.push(ref);
                contentAssets.push(ref);
                
                // Track gallery usage
                const galleryMatch = ref.sourceUrl.match(/\/MediaGroupings\/(\d+)\//);
                if (galleryMatch) {
                    const galleryId = parseInt(galleryMatch[1]);
                    galleryUsage.set(galleryId, (galleryUsage.get(galleryId) || 0) + 1);
                }
            });
            
            if (contentAssets.length > 0) {
                assetsByContent.set(content.contentID, contentAssets);
            }
        }
        
        // Calculate unused assets (we'd need the full asset list for this)
        const uniqueUsedUrls = new Set(usedAssets.map(ref => ref.sourceUrl));
        
        return {
            totalAssets: 0, // Would need full asset list
            usedAssets,
            unusedAssets: [], // Would calculate from full asset list
            assetsByContent,
            galleryUsage,
            optimizationPotential: {
                assetsToSkip: 0, // Would calculate
                sizeReduction: `${uniqueUsedUrls.size} assets will be migrated`,
                migrationSpeedup: 'Significant reduction in asset processing time'
            }
        };
    }

    /**
     * Extract nested content references from content fields
     */
    private extractNestedContentReferences(fields: Record<string, any>): Array<{
        contentID: number;
        fieldPath: string;
        isRequired: boolean;
    }> {
        const references: Array<{ contentID: number; fieldPath: string; isRequired: boolean }> = [];
        
        // Add null check for fields
        if (!fields || typeof fields !== 'object') {
            return references;
        }
        
        const scanForContentRefs = (obj: any, path: string) => {
            if (typeof obj !== 'object' || obj === null) return;
            
            if (Array.isArray(obj)) {
                obj.forEach((item, index) => {
                    scanForContentRefs(item, `${path}[${index}]`);
                });
            } else {
                // Check for content ID references
                if (obj.contentID && typeof obj.contentID === 'number' && obj.contentID > 0) {
                    references.push({
                        contentID: obj.contentID,
                        fieldPath: `${path}.contentID`,
                        isRequired: true
                    });
                }
                
                if (obj.contentid && typeof obj.contentid === 'number' && obj.contentid > 0) {
                    references.push({
                        contentID: obj.contentid,
                        fieldPath: `${path}.contentid`,
                        isRequired: true
                    });
                }
                
                // Recursively scan nested objects
                for (const [key, value] of Object.entries(obj)) {
                    scanForContentRefs(value, path ? `${path}.${key}` : key);
                }
            }
        };
        
        for (const [fieldName, fieldValue] of Object.entries(fields)) {
            scanForContentRefs(fieldValue, `fields.${fieldName}`);
        }
        
        return references;
    }

    /**
     * Extract asset references from content fields
     */
    private extractAssetReferences(fields: Record<string, any>, contentId: number): AssetReference[] {
        const references: AssetReference[] = [];
        
        // Add null check for fields
        if (!fields || typeof fields !== 'object') {
            return references;
        }
        
        const scanForAssetRefs = (obj: any, path: string, contentId: number) => {
            if (typeof obj !== 'object' || obj === null) return;
            
            if (Array.isArray(obj)) {
                obj.forEach((item, index) => {
                    scanForAssetRefs(item, `${path}[${index}]`, contentId);
                });
            } else {
                // Check for URL references
                if (obj.url && typeof obj.url === 'string' && obj.url.startsWith('http')) {
                    const normalizedUrl = this.normalizeAssetUrl(obj.url);
                    const usage = obj.url.includes('/MediaGroupings/') ? 'gallery' : 'direct';
                    references.push({
                        sourceUrl: normalizedUrl,
                        contentId,
                        fieldPath: `${path}.url`,
                        isRequired: false,
                        usage
                    });
                }
                
                // Also check for other common asset field patterns
                if (obj.src && typeof obj.src === 'string' && obj.src.startsWith('http')) {
                    const normalizedUrl = this.normalizeAssetUrl(obj.src);
                    const usage = obj.src.includes('/MediaGroupings/') ? 'gallery' : 'direct';
                    references.push({
                        sourceUrl: normalizedUrl,
                        contentId,
                        fieldPath: `${path}.src`,
                        isRequired: false,
                        usage
                    });
                }
                
                // Recursively scan nested objects
                for (const [key, value] of Object.entries(obj)) {
                    scanForAssetRefs(value, path ? `${path}.${key}` : key, contentId);
                }
            }
        };
        
        for (const [fieldName, fieldValue] of Object.entries(fields)) {
            scanForAssetRefs(fieldValue, `fields.${fieldName}`, contentId);
        }
        
        return references;
    }

    /**
     * Extract content references from page zones
     */
    private extractPageZoneContentReferences(zones: any): Array<{
        contentID: number;
        fieldPath: string;
    }> {
        const references: Array<{ contentID: number; fieldPath: string }> = [];
        
        if (!zones || typeof zones !== 'object') return references;
        
        for (const [zoneName, zoneModules] of Object.entries(zones)) {
            if (Array.isArray(zoneModules)) {
                zoneModules.forEach((module, index) => {
                    // Check for both contentId and contentID variants
                    if (module?.item?.contentid && typeof module.item.contentid === 'number') {
                        references.push({
                            contentID: module.item.contentid,
                            fieldPath: `zones.${zoneName}[${index}].item.contentid`
                        });
                    } else if (module?.item?.contentId && typeof module.item.contentId === 'number') {
                        references.push({
                            contentID: module.item.contentId,
                            fieldPath: `zones.${zoneName}[${index}].item.contentId`
                        });
                    }
                });
            }
        }
        
        return references;
    }

    /**
     * Add dependencies to the graph
     */
    private addDependenciesToGraph(dependencies: EntityDependency[], graph: UniversalDependencyGraph): void {
        const missingEntities: { dependency: EntityDependency; reason: string }[] = [];
        
        dependencies.forEach(dep => {
            // Add relationship edge
            graph.relationships.push({
                from: dep.sourceEntity,
                to: dep.targetEntity,
                relationship: dep.relationship,
                isRequired: dep.isRequired,
                fieldPath: dep.fieldPath,
                resolutionStrategy: dep.resolutionStrategy
            });
            
            // Update entity nodes
            const sourceNode = graph.entities.get(dep.sourceEntity);
            const targetNode = graph.entities.get(dep.targetEntity);
            
            if (sourceNode && targetNode) {
                sourceNode.dependencies.push(dep.targetEntity);
                targetNode.dependents.push(dep.sourceEntity);
            } else {
                // Track missing relationships but don't spam console with useless warnings
                let reason = '';
                if (!sourceNode && !targetNode) {
                    reason = 'Both source and target entities missing';
                } else if (!sourceNode) {
                    reason = 'Source entity missing';
                } else {
                    reason = 'Target entity missing';
                }
                
                missingEntities.push({ dependency: dep, reason });
            }
        });
        
        // Note: Removed useless "broken relationships will be reported in summary" message
        // since we already show specific missing dependencies (like templates) where it matters
    }

    /**
     * Detect cycles in the dependency graph using DFS
     */
    private detectCycles(graph: UniversalDependencyGraph): DependencyCycle[] {
        const visited = new Set<string>();
        const recursionStack = new Set<string>();
        const cycles: DependencyCycle[] = [];
        
        const dfs = (entityKey: string, path: string[]): boolean => {
            visited.add(entityKey);
            recursionStack.add(entityKey);
            path.push(entityKey);
            
            const node = graph.entities.get(entityKey as EntityKey);
            if (!node) return false;
            
            for (const dependentKey of node.dependencies) {
                if (!visited.has(dependentKey)) {
                    if (dfs(dependentKey, [...path])) {
                        return true;
                    }
                } else if (recursionStack.has(dependentKey)) {
                    // Found cycle
                    const cycleStart = path.indexOf(dependentKey);
                    const cycleEntities = path.slice(cycleStart);
                    cycleEntities.push(dependentKey);
                    
                    cycles.push(this.createCycleFromPath(cycleEntities as EntityKey[], graph));
                    return true;
                }
            }
            
            recursionStack.delete(entityKey);
            return false;
        };
        
        // Use Array.from() to convert Map iterator
        for (const entityKey of Array.from(graph.entities.keys())) {
            if (!visited.has(entityKey)) {
                dfs(entityKey, []);
            }
        }
        
        return cycles;
    }

    /**
     * Create a cycle object from a detected path
     */
    private createCycleFromPath(entities: EntityKey[], graph: UniversalDependencyGraph): DependencyCycle {
        const relationships: RelationshipType[] = [];
        
        for (let i = 0; i < entities.length - 1; i++) {
            const relationship = graph.relationships.find(r => 
                r.from === entities[i] && r.to === entities[i + 1]
            );
            if (relationship) {
                relationships.push(relationship.relationship);
            }
        }
        
        const entityTypes = entities.map(e => parseEntityKey(e).type);
        const hasMultipleTypes = new Set(entityTypes).size > 1;
        
        return {
            entities,
            relationships,
            cycleLength: entities.length - 1,
            severity: hasMultipleTypes ? 'cross_entity' : (entities.length > 3 ? 'complex' : 'simple'),
            isBreakable: this.determineCycleBreakability(relationships),
            breakPoints: this.identifyBreakPoints(entities, relationships)
        };
    }

    /**
     * Determine if a cycle can be broken
     */
    private determineCycleBreakability(relationships: RelationshipType[]): boolean {
        // Cycles with optional relationships are always breakable
        return relationships.some(rel => 
            rel === RelationshipType.CONTENT_TO_CONTENT ||
            rel === RelationshipType.ASSET_TO_CONTENT ||
            rel === RelationshipType.CONTENT_TO_PAGE
        );
    }

    /**
     * Identify potential break points in a cycle
     */
    private identifyBreakPoints(entities: EntityKey[], relationships: RelationshipType[]): EntityKey[] {
        const breakPoints: EntityKey[] = [];
        
        relationships.forEach((rel, index) => {
            if (rel === RelationshipType.CONTENT_TO_CONTENT ||
                rel === RelationshipType.ASSET_TO_CONTENT ||
                rel === RelationshipType.CONTENT_TO_PAGE) {
                breakPoints.push(entities[index]);
            }
        });
        
        return breakPoints;
    }

    /**
     * Generate optimal processing order based on dependencies
     */
    private generateProcessingOrder(graph: UniversalDependencyGraph): EntityKey[] {
        const order: EntityKey[] = [];
        const visited = new Set<string>();
        const temp = new Set<string>();
        
        const visit = (entityKey: string) => {
            if (temp.has(entityKey)) {
                // Circular dependency - skip for now
                return;
            }
            if (visited.has(entityKey)) return;
            
            temp.add(entityKey);
            
            const node = graph.entities.get(entityKey as EntityKey);
            if (node) {
                // Visit all dependencies first
                node.dependencies.forEach(dep => visit(dep));
            }
            
            temp.delete(entityKey);
            visited.add(entityKey);
            order.push(entityKey as EntityKey);
        };
        
        // Sort entities by type priority and then by individual priority
        const sortedEntities = Array.from(graph.entities.values()).sort((a, b) => {
            const typePriority = { gallery: 1, asset: 2, model: 3, container: 4, template: 5, content: 6, page: 7 };
            const aPriority = typePriority[a.type] || 999;
            const bPriority = typePriority[b.type] || 999;
            
            if (aPriority !== bPriority) return aPriority - bPriority;
            return a.priority - b.priority;
        });
        
        sortedEntities.forEach(entity => {
            if (!visited.has(entity.key)) {
                visit(entity.key);
            }
        });
        
        return order;
    }

    /**
     * Report analysis results
     */
    private reportAnalysisResults(graph: UniversalDependencyGraph): void {
        if (!this.debug) return; // Only show in debug mode
        
        console.log(ansiColors.green(`[Dependency Analyzer] Analysis complete:`));
        console.log(ansiColors.cyan(`  - ${graph.entities.size} entities analyzed`));
        console.log(ansiColors.cyan(`  - ${graph.relationships.length} dependency relationships found`));
        console.log(ansiColors.cyan(`  - ${graph.cycles.length} circular dependencies detected`));
        console.log(ansiColors.cyan(`  - ${graph.usedAssets.size} assets marked as used`));
        
        if (graph.cycles.length > 0) {
            console.log(ansiColors.yellow(`[Dependency Analyzer] Cycles detected:`));
            graph.cycles.forEach((cycle, index) => {
                const entityList = cycle.entities.map(e => parseEntityKey(e).type + ':' + parseEntityKey(e).id).join(' → ');
                console.log(ansiColors.yellow(`  ${index + 1}. ${cycle.severity} cycle: ${entityList}`));
            });
        }
    }

    /**
     * Build dependency chains from Content Items and Pages as starting points
     * This provides a clearer view of what actually needs to be processed
     */
    async buildDependencyChains(entities: {
        galleries?: mgmtApi.assetGalleries[];
        assets?: mgmtApi.Media[];
        models?: mgmtApi.Model[];
        containers?: mgmtApi.Container[];
        content?: mgmtApi.ContentItem[];
        templates?: mgmtApi.PageModel[];
        pages?: mgmtApi.PageItem[];
    }): Promise<DependencyChainAnalysis> {
        const analysis: DependencyChainAnalysis = {
            contentChains: [],
            pageChains: [],
            cycles: [],
            nonDependentItems: {
                galleries: [],
                assets: [],
                models: [],
                containers: [],
                content: [],
                templates: [],
                pages: []
            },
            chainStats: {
                totalChains: 0,
                totalCycles: 0,
                longestChain: 0,
                avgChainLength: 0
            },
            entityCounts: {
                total: { galleries: 0, assets: 0, models: 0, containers: 0, content: 0, templates: 0, pages: 0 },
                inChains: { galleries: 0, assets: 0, models: 0, containers: 0, content: 0, templates: 0, pages: 0 },
                nonDependent: { galleries: 0, assets: 0, models: 0, containers: 0, content: 0, templates: 0, pages: 0 },
                inCycles: { galleries: 0, assets: 0, models: 0, containers: 0, content: 0, templates: 0, pages: 0 }
            }
        };

        const entitiesInChains = new Set<EntityKey>();
        
        // Create URL-to-mediaID mapping for consistent asset entity keys
        const assetUrlToIdMap = new Map<string, number>();
        if (entities.assets) {
            entities.assets.forEach((asset) => {
                if (asset.originUrl) {
                    const normalizedUrl = this.normalizeAssetUrl(asset.originUrl);
                    assetUrlToIdMap.set(normalizedUrl, asset.mediaID);
                    
                    // Also map the original URL if different
                    if (normalizedUrl !== asset.originUrl) {
                        assetUrlToIdMap.set(asset.originUrl, asset.mediaID);
                    }
                }
            });
        }

        // Build chains from Content Items and Pages as starting points
        
        if (entities.content) {
            let contentChainsBuilt = 0;
            for (const contentItem of entities.content) {
                const dependencies = this.getInterestingEntityDependencies('content', contentItem, entities, assetUrlToIdMap);
                
                if (dependencies.length > 0) {
                    const chain = await this.buildChainFromContent(contentItem, entities, entitiesInChains, assetUrlToIdMap);
                    analysis.contentChains.push(chain);
                    this.markEntitiesInChain(chain, entitiesInChains);
                    contentChainsBuilt++;
                }
            }
        }

        if (entities.pages) {
            let pageChainsBuilt = 0;
            for (const page of entities.pages) {
                const dependencies = this.getInterestingEntityDependencies('page', page, entities, assetUrlToIdMap);
                
                if (dependencies.length > 0) {
                    const chain = await this.buildChainFromPage(page, entities, entitiesInChains, assetUrlToIdMap);
                    analysis.pageChains.push(chain);
                    this.markEntitiesInChain(chain, entitiesInChains);
                    pageChainsBuilt++;
                }
            }
        }

        // Add Container chains as well - containers can also be starting points
        if (entities.containers) {
            let containerChainsBuilt = 0;
            for (const container of entities.containers) {
                const dependencies = this.getInterestingEntityDependencies('container', container, entities, assetUrlToIdMap);
                
                if (dependencies.length > 0) {
                    // Build a simple chain for container dependencies
                    const chain: DependencyChain = {
                        rootEntity: createEntityKey('container', container.contentViewID),
                        rootType: 'container',
                        dependencies: [],
                        totalDepth: 1
                    };
                    
                    // Convert container dependencies to chain nodes
                    dependencies.forEach(dep => {
                        chain.dependencies.push({
                            entity: dep.targetEntity,
                            relationship: dep.relationship,
                            isRequired: dep.isRequired,
                            fieldPath: dep.fieldPath,
                            depth: 1,
                            children: []
                        });
                    });
                    
                    analysis.contentChains.push(chain); // Add to content chains for now
                    this.markEntitiesInChain(chain, entitiesInChains);
                    containerChainsBuilt++;
                }
            }
        }

        // Rest of the method remains the same...
        this.identifyNonDependentItems(entities, entitiesInChains, analysis);
        this.calculateEntityCounts(entities, entitiesInChains, analysis, assetUrlToIdMap);
        this.calculateChainStatistics(analysis);
        
        if (this.debug) {
            this.reportDependencyChains(analysis);
        }

        return analysis;
    }

    /**
     * Build dependency chain starting from a content item
     * Only tracks nested/complex dependencies, not simple content→model
     */
    private async buildChainFromContent(
        contentItem: mgmtApi.ContentItem, 
        entities: any, 
        entitiesInChains: Set<EntityKey>,
        assetUrlToIdMap: Map<string, number>
    ): Promise<DependencyChain> {
        const chain: DependencyChain = {
            rootEntity: createEntityKey('content', contentItem.contentID),
            rootType: 'content',
            dependencies: [],
            totalDepth: 0
        };

        const visited = new Set<EntityKey>();
        
        // Only build dependency tree for interesting relationships
        await this.buildNestedDependencyTree(chain.rootEntity, entities, chain.dependencies, visited, 0, assetUrlToIdMap);
        
        chain.totalDepth = this.calculateMaxDepth(chain.dependencies);
        
        return chain;
    }

    /**
     * Build dependency chain starting from a page
     * Only tracks nested/complex dependencies
     */
    private async buildChainFromPage(
        page: mgmtApi.PageItem, 
        entities: any, 
        entitiesInChains: Set<EntityKey>,
        assetUrlToIdMap: Map<string, number>
    ): Promise<DependencyChain> {
        const chain: DependencyChain = {
            rootEntity: createEntityKey('page', page.pageID),
            rootType: 'page',
            dependencies: [],
            totalDepth: 0
        };

        const visited = new Set<EntityKey>();
        
        // Only build dependency tree for interesting relationships
        await this.buildNestedDependencyTree(chain.rootEntity, entities, chain.dependencies, visited, 0, assetUrlToIdMap);
        
        chain.totalDepth = this.calculateMaxDepth(chain.dependencies);
        
        return chain;
    }

    /**
     * Build dependency tree focusing only on nested/complex relationships
     */
    private async buildNestedDependencyTree(
        entityKey: EntityKey,
        entities: any,
        dependencies: DependencyNode[],
        visited: Set<EntityKey>,
        depth: number,
        assetUrlToIdMap: Map<string, number>
    ): Promise<void> {
        if (visited.has(entityKey) || depth > 10) { // Prevent infinite recursion
            return;
        }
        
        visited.add(entityKey);
        const { type, id } = parseEntityKey(entityKey);
        
        // Find the actual entity data
        const entityData = this.findEntityData(type, id, entities);
        if (!entityData) return;

        // Get only interesting dependencies for this entity
        const entityDependencies = this.getInterestingEntityDependencies(type, entityData, entities, assetUrlToIdMap);
        
        for (const dep of entityDependencies) {
            const depNode: DependencyNode = {
                entity: dep.targetEntity,
                relationship: dep.relationship,
                isRequired: dep.isRequired,
                fieldPath: dep.fieldPath,
                depth: depth + 1,
                children: []
            };
            
            dependencies.push(depNode);
            
            // Recursively build dependencies for this node
            await this.buildNestedDependencyTree(dep.targetEntity, entities, depNode.children, visited, depth + 1, assetUrlToIdMap);
        }
    }

    /**
     * Get only interesting dependencies - skip obvious ones like content→model
     */
    private getInterestingEntityDependencies(type: EntityType, entityData: any, entities: any, assetUrlToIdMap: Map<string, number>): EntityDependency[] {
        const allDeps = this.getEntityDependencies(type, entityData, entities, assetUrlToIdMap);
        
        // Filter to only interesting/nested dependencies
        const interestingDeps = allDeps.filter(dep => {
            // Keep interesting relationships:
            // - Content referencing other content (nested)
            // - Pages referencing other pages (hierarchy)
            // - Content referencing assets (media usage)
            // - Pages referencing content (page content)
            // - Complex template relationships
            // - Container dependencies (containers bound to models, containers bound to templates/content)
            // - Content referencing models (needed for chain analysis even if "obvious")
            const isInteresting = dep.relationship === RelationshipType.CONTENT_TO_CONTENT ||
                   dep.relationship === RelationshipType.PAGE_TO_PAGE ||
                   dep.relationship === RelationshipType.CONTENT_TO_ASSET ||
                   dep.relationship === RelationshipType.CONTENT_TO_PAGE ||
                   dep.relationship === RelationshipType.TEMPLATE_TO_PAGE ||
                   dep.relationship === RelationshipType.GALLERY_TO_ASSET ||
                   dep.relationship === RelationshipType.CONTAINER_TO_MODEL ||
                   dep.relationship === RelationshipType.CONTAINER_TO_CONTENT ||
                   dep.relationship === RelationshipType.CONTAINER_TO_TEMPLATE ||
                   dep.relationship === RelationshipType.MODEL_TO_CONTENT; // Include content→model for chain analysis
                   
            return isInteresting;
        });
        
        return interestingDeps;
    }

    /**
     * Find entity data by type and ID
     */
    private findEntityData(type: EntityType, id: string | number, entities: any): any {
        switch (type) {
            case 'content':
                return entities.content?.find((c: any) => c.contentID === id);
            case 'page':
                return entities.pages?.find((p: any) => p.pageID === id);
            case 'model':
                return entities.models?.find((m: any) => m.referenceName === id);
            case 'container':
                return entities.containers?.find((c: any) => c.contentViewID === id);
            case 'template':
                return entities.templates?.find((t: any) => t.pageTemplateName === id);
            case 'asset':
                return entities.assets?.find((a: any) => a.mediaID === id);
            case 'gallery':
                return entities.galleries?.find((g: any) => g.assetMediaGroupings?.[0]?.mediaGroupingID === id);
            default:
                return null;
        }
    }

    /**
     * Get dependencies for a specific entity
     */
    private getEntityDependencies(type: EntityType, entityData: any, entities: any, assetUrlToIdMap?: Map<string, number>): EntityDependency[] {
        switch (type) {
            case 'content':
                return this.analyzeContentDependencies(entityData, new Set(), assetUrlToIdMap);
            case 'page':
                return this.analyzePageDependencies(entityData);
            case 'model':
                return this.analyzeModelDependencies(entityData);
            case 'container':
                return this.analyzeContainerDependencies(entityData, entities);
            case 'template':
                return this.analyzeTemplateDependencies(entityData);
            case 'asset':
                return this.analyzeAssetDependencies(entityData);
            default:
                return [];
        }
    }

    /**
     * Mark all entities in a chain as involved
     */
    private markEntitiesInChain(chain: DependencyChain, entitiesInChains: Set<EntityKey>): void {
        entitiesInChains.add(chain.rootEntity);
        
        const markDependencies = (deps: DependencyNode[]) => {
            for (const dep of deps) {
                entitiesInChains.add(dep.entity);
                markDependencies(dep.children);
            }
        };
        
        markDependencies(chain.dependencies);
    }

    /**
     * Identify items that are not involved in any dependency chains
     */
    private identifyNonDependentItems(
        entities: any, 
        entitiesInChains: Set<EntityKey>, 
        analysis: DependencyChainAnalysis
    ): void {
        // Check each entity type
        if (entities.galleries) {
            entities.galleries.forEach((g: any) => {
                const key = createEntityKey('gallery', g.assetMediaGroupings?.[0]?.mediaGroupingID || g.id);
                if (!entitiesInChains.has(key)) {
                    analysis.nonDependentItems.galleries.push(g);
                }
            });
        }

        if (entities.assets) {
            entities.assets.forEach((a: any) => {
                // Create both mediaID and URL-based keys for checking
                const mediaIdKey = createEntityKey('asset', a.mediaID);
                const urlKey = a.originUrl ? createEntityKey('asset', a.originUrl) : null;
                
                // An asset is considered "in chains" if either its mediaID or URL is referenced
                let isInChain = entitiesInChains.has(mediaIdKey);
                if (!isInChain && urlKey) {
                    isInChain = entitiesInChains.has(urlKey);
                }
                
                if (!isInChain) {
                    analysis.nonDependentItems.assets.push(a);
                }
            });
        }

        if (entities.models) {
            entities.models.forEach((m: any) => {
                const key = createEntityKey('model', m.referenceName);
                if (!entitiesInChains.has(key)) {
                    analysis.nonDependentItems.models.push(m);
                }
            });
        }

        if (entities.containers) {
            entities.containers.forEach((c: any) => {
                const key = createEntityKey('container', c.contentViewID);
                if (!entitiesInChains.has(key)) {
                    analysis.nonDependentItems.containers.push(c);
                }
            });
        }

        if (entities.content) {
            entities.content.forEach((c: any) => {
                const key = createEntityKey('content', c.contentID);
                if (!entitiesInChains.has(key)) {
                    analysis.nonDependentItems.content.push(c);
                }
            });
        }

        if (entities.templates) {
            entities.templates.forEach((t: any) => {
                const key = createEntityKey('template', t.pageTemplateName);
                if (!entitiesInChains.has(key)) {
                    analysis.nonDependentItems.templates.push(t);
                }
            });
        }

        if (entities.pages) {
            entities.pages.forEach((p: any) => {
                const key = createEntityKey('page', p.pageID);
                if (!entitiesInChains.has(key)) {
                    analysis.nonDependentItems.pages.push(p);
                }
            });
        }
    }

    /**
     * Calculate maximum depth in dependency tree
     */
    private calculateMaxDepth(dependencies: DependencyNode[]): number {
        let maxDepth = 0;
        
        const traverse = (deps: DependencyNode[]) => {
            for (const dep of deps) {
                maxDepth = Math.max(maxDepth, dep.depth);
                traverse(dep.children);
            }
        };
        
        traverse(dependencies);
        return maxDepth;
    }

    /**
     * Calculate chain statistics
     */
    private calculateChainStatistics(analysis: DependencyChainAnalysis): void {
        const allChains = [...analysis.contentChains, ...analysis.pageChains];
        analysis.chainStats.totalChains = allChains.length;
        analysis.chainStats.totalCycles = analysis.cycles.length;
        
        if (allChains.length > 0) {
            analysis.chainStats.longestChain = Math.max(...allChains.map(c => c.totalDepth));
            analysis.chainStats.avgChainLength = allChains.reduce((sum, c) => sum + c.totalDepth, 0) / allChains.length;
        }
    }

    /**
     * Report the dependency chain analysis
     */
    private reportDependencyChains(analysis: DependencyChainAnalysis): void {
        console.log(ansiColors.cyan('\n📊 DEPENDENCY CHAIN ANALYSIS'));
        console.log(ansiColors.cyan('=' .repeat(50)));
        
        // Overall statistics
        console.log(ansiColors.yellow('\n📈 CHAIN STATISTICS:'));
        console.log(ansiColors.cyan(`  🔗 Total Chains: ${analysis.chainStats.totalChains}`));
        console.log(ansiColors.cyan(`  📄 Content Chains: ${analysis.contentChains.length}`));
        console.log(ansiColors.cyan(`  📃 Page Chains: ${analysis.pageChains.length}`));
        console.log(ansiColors.cyan(`  🔄 Cycles: ${analysis.chainStats.totalCycles}`));
        console.log(ansiColors.cyan(`  📏 Longest Chain: ${analysis.chainStats.longestChain} levels`));
        console.log(ansiColors.cyan(`  📊 Average Chain Length: ${analysis.chainStats.avgChainLength.toFixed(1)} levels`));

        // Detailed entity breakdown
        console.log(ansiColors.yellow('\n📋 ENTITY TYPE BREAKDOWN:'));
        const entities = ['galleries', 'assets', 'models', 'containers', 'content', 'templates', 'pages'] as const;
        const icons = ['📁', '🖼️', '📐', '📦', '📄', '📋', '📃'];
        
        entities.forEach((entityType, index) => {
            const total = analysis.entityCounts.total[entityType];
            const inChains = analysis.entityCounts.inChains[entityType];
            const nonDependent = analysis.entityCounts.nonDependent[entityType];
            const inCycles = analysis.entityCounts.inCycles[entityType];
            
            console.log(ansiColors.cyan(`\n  ${icons[index]} ${entityType.toUpperCase()}:`));
            console.log(ansiColors.cyan(`    📊 Total: ${total}`));
            console.log(ansiColors.green(`    🔗 In Chains: ${inChains}`));
            console.log(ansiColors.yellow(`    🔴 Non-Dependent: ${nonDependent}`));
            console.log(ansiColors.red(`    🔄 In Cycles: ${inCycles}`));
            
            // Verification
            const accountedFor = inChains + nonDependent;
            if (accountedFor === total) {
                console.log(ansiColors.green(`    ✅ All ${total} items accounted for`));
            } else {
                console.log(ansiColors.red(`    ❌ Missing ${total - accountedFor} items (${accountedFor}/${total} accounted for)`));
            }
        });

        // Summary verification
        console.log(ansiColors.yellow('\n🔍 VERIFICATION SUMMARY:'));
        let totalEntities = 0;
        let totalInChains = 0;
        let totalNonDependent = 0;
        let totalInCycles = 0;
        
        entities.forEach(entityType => {
            totalEntities += analysis.entityCounts.total[entityType];
            totalInChains += analysis.entityCounts.inChains[entityType];
            totalNonDependent += analysis.entityCounts.nonDependent[entityType];
            totalInCycles += analysis.entityCounts.inCycles[entityType];
        });
        
        console.log(ansiColors.cyan(`  📊 Total Entities: ${totalEntities}`));
        console.log(ansiColors.green(`  🔗 Total In Chains: ${totalInChains}`));
        console.log(ansiColors.yellow(`  🔴 Total Non-Dependent: ${totalNonDependent}`));
        console.log(ansiColors.red(`  🔄 Total In Cycles: ${totalInCycles}`));
        
        const totalAccountedFor = totalInChains + totalNonDependent;
        if (totalAccountedFor === totalEntities) {
            console.log(ansiColors.green(`  ✅ ALL ${totalEntities} ENTITIES ACCOUNTED FOR`));
        } else {
            console.log(ansiColors.red(`  ❌ MISSING ${totalEntities - totalAccountedFor} ENTITIES`));
        }

        // Show actual chains (first few)
        if (analysis.contentChains.length > 0) {
            console.log(ansiColors.yellow('\n📄 CONTENT CHAINS (showing first 3):'));
            analysis.contentChains.slice(0, 3).forEach((chain, index) => {
                console.log(ansiColors.green(`\n  Chain ${index + 1}: ${chain.rootEntity} (depth: ${chain.totalDepth})`));
                this.printDependencyTree(chain.dependencies, '    ');
            });
            if (analysis.contentChains.length > 3) {
                console.log(ansiColors.cyan(`    ... and ${analysis.contentChains.length - 3} more content chains`));
            }
        }

        if (analysis.pageChains.length > 0) {
            console.log(ansiColors.yellow('\n📃 PAGE CHAINS (showing first 3):'));
            analysis.pageChains.slice(0, 3).forEach((chain, index) => {
                console.log(ansiColors.green(`\n  Chain ${index + 1}: ${chain.rootEntity} (depth: ${chain.totalDepth})`));
                this.printDependencyTree(chain.dependencies, '    ');
            });
            if (analysis.pageChains.length > 3) {
                console.log(ansiColors.cyan(`    ... and ${analysis.pageChains.length - 3} more page chains`));
            }
        }

        if (analysis.cycles.length > 0) {
            console.log(ansiColors.red('\n🔄 DETECTED CYCLES:'));
            analysis.cycles.forEach((cycle, index) => {
                console.log(ansiColors.red(`  ${index + 1}. ${cycle.entities.join(' → ')}`));
            });
        }
    }

    /**
     * Print dependency tree in a readable format
     */
    private printDependencyTree(dependencies: DependencyNode[], indent: string): void {
        for (const dep of dependencies) {
            // Use green emojis for successful chains - red looks broken
            const statusIcon = dep.isRequired ? '🟢' : '🟡';
            console.log(ansiColors.cyan(`${indent}${statusIcon} ${dep.entity} (${dep.relationship})`));
            if (dep.children.length > 0) {
                this.printDependencyTree(dep.children, indent + '  ');
            }
        }
    }

    /**
     * Calculate entity counts
     */
    private calculateEntityCounts(entities: any, entitiesInChains: Set<EntityKey>, analysis: DependencyChainAnalysis, assetUrlToIdMap: Map<string, number>): void {
        // Count total entities by type
        analysis.entityCounts.total.galleries = entities.galleries?.length || 0;
        analysis.entityCounts.total.assets = entities.assets?.length || 0;
        analysis.entityCounts.total.models = entities.models?.length || 0;
        analysis.entityCounts.total.containers = entities.containers?.length || 0;
        analysis.entityCounts.total.content = entities.content?.length || 0;
        analysis.entityCounts.total.templates = entities.templates?.length || 0;
        analysis.entityCounts.total.pages = entities.pages?.length || 0;

        // Count non-dependent entities (already calculated in identifyNonDependentItems)
        analysis.entityCounts.nonDependent.galleries = analysis.nonDependentItems.galleries.length;
        analysis.entityCounts.nonDependent.assets = analysis.nonDependentItems.assets.length;
        analysis.entityCounts.nonDependent.models = analysis.nonDependentItems.models.length;
        analysis.entityCounts.nonDependent.containers = analysis.nonDependentItems.containers.length;
        analysis.entityCounts.nonDependent.content = analysis.nonDependentItems.content.length;
        analysis.entityCounts.nonDependent.templates = analysis.nonDependentItems.templates.length;
        analysis.entityCounts.nonDependent.pages = analysis.nonDependentItems.pages.length;

        // Count entities in chains - use Set to avoid double counting
        const chainEntityCounts = {
            galleries: 0,
            assets: 0,
            models: 0,
            containers: 0,
            content: 0,
            templates: 0,
            pages: 0
        };

        // Track unique assets to avoid double counting URL vs mediaID
        const uniqueAssetsInChains = new Set<number>();

        for (const entityKey of Array.from(entitiesInChains)) {
            const { type, id } = parseEntityKey(entityKey);
            switch (type) {
                case 'gallery':
                    chainEntityCounts.galleries++;
                    break;
                case 'asset':
                    // For assets, check if it's a URL or mediaID and normalize to mediaID
                    if (typeof id === 'string' && id.startsWith('http')) {
                        // It's a URL, find the corresponding mediaID
                        const mediaId = assetUrlToIdMap.get(id);
                        if (mediaId && !uniqueAssetsInChains.has(mediaId)) {
                            uniqueAssetsInChains.add(mediaId);
                            chainEntityCounts.assets++;
                        }
                    } else {
                        // It's already a mediaID
                        const mediaId = typeof id === 'number' ? id : parseInt(id.toString());
                        if (!uniqueAssetsInChains.has(mediaId)) {
                            uniqueAssetsInChains.add(mediaId);
                            chainEntityCounts.assets++;
                        }
                    }
                    break;
                case 'model':
                    chainEntityCounts.models++;
                    break;
                case 'container':
                    chainEntityCounts.containers++;
                    break;
                case 'content':
                    chainEntityCounts.content++;
                    break;
                case 'template':
                    chainEntityCounts.templates++;
                    break;
                case 'page':
                    chainEntityCounts.pages++;
                    break;
            }
        }

        analysis.entityCounts.inChains = chainEntityCounts;

        // Count entities in cycles
        const cycleEntityCounts = {
            galleries: 0,
            assets: 0,
            models: 0,
            containers: 0,
            content: 0,
            templates: 0,
            pages: 0
        };

        const entitiesInCycles = new Set<EntityKey>();
        analysis.cycles.forEach(cycle => {
            cycle.entities.forEach(entityKey => entitiesInCycles.add(entityKey));
        });

        for (const entityKey of Array.from(entitiesInCycles)) {
            const { type } = parseEntityKey(entityKey);
            switch (type) {
                case 'gallery':
                    cycleEntityCounts.galleries++;
                    break;
                case 'asset':
                    cycleEntityCounts.assets++;
                    break;
                case 'model':
                    cycleEntityCounts.models++;
                    break;
                case 'container':
                    cycleEntityCounts.containers++;
                    break;
                case 'content':
                    cycleEntityCounts.content++;
                    break;
                case 'template':
                    cycleEntityCounts.templates++;
                    break;
                case 'page':
                    cycleEntityCounts.pages++;
                    break;
            }
        }

        analysis.entityCounts.inCycles = cycleEntityCounts;
    }

    /**
     * Simplified Chain Analysis - Focus on Real Execution Chains
     * 
     * This analysis focuses on what matters for parallel execution:
     * - Entry points (Pages, Content Items)  
     * - Their complete dependency chains
     * - Broken vs Complete chains
     * - Visual representation
     */
    async buildExecutionChains(entities: {
        galleries?: mgmtApi.assetGalleries[];
        assets?: mgmtApi.Media[];
        models?: mgmtApi.Model[];
        containers?: mgmtApi.Container[];
        content?: mgmtApi.ContentItem[];
        templates?: mgmtApi.PageModel[];
        pages?: mgmtApi.PageItem[];
    }): Promise<ExecutionChainAnalysis> {
        
        const analysis: ExecutionChainAnalysis = {
            completeChains: [],
            brokenChains: [],
            standaloneItems: {
                content: [],
                pages: []
            },
            summary: {
                totalExecutableChains: 0,
                totalBrokenChains: 0,
                totalStandaloneItems: 0,
                parallelExecutionGroups: 0
            }
        };

        const processedEntities = new Set<EntityKey>();
        const assetUrlToIdMap = this.createAssetUrlMapping(entities.assets || []);
        
        // Step 1: Analyze Page Chains (Entry Points)
        if (entities.pages) {
            for (const page of entities.pages) {
                const chain = await this.buildPageExecutionChain(page, entities, assetUrlToIdMap);
                
                if (chain.isComplete) {
                    analysis.completeChains.push(chain);
                } else {
                    analysis.brokenChains.push(chain);
                    // The specific missing dependencies are already logged in buildExecutionDependencyTree
                }
                
                this.markChainEntities(chain, processedEntities);
            }
        }

        // Step 2: Analyze Content Chains (Entry Points) - Only those with nested content
        if (entities.content) {
            for (const content of entities.content) {
                const contentKey = createEntityKey('content', content.contentID);
                if (processedEntities.has(contentKey)) continue; // Already processed as part of page chain
                
                // Only analyze content that has nested content references
                const dependencies = this.getInterestingEntityDependencies('content', content, entities, assetUrlToIdMap);
                const hasNestedContent = dependencies.some(dep => dep.relationship === RelationshipType.CONTENT_TO_CONTENT);
                
                if (hasNestedContent) {
                    const chain = await this.buildContentExecutionChain(content, entities, assetUrlToIdMap);
                    
                    if (chain.isComplete) {
                        analysis.completeChains.push(chain);
                    } else {
                        analysis.brokenChains.push(chain);
                        // The specific missing dependencies are already logged in buildExecutionDependencyTree
                    }
                    
                    this.markChainEntities(chain, processedEntities);
                }
            }
        }

        // Step 3: Identify Standalone Items (no complex dependencies)
        this.identifyStandaloneItems(entities, processedEntities, analysis);
        
        // Step 4: Calculate Summary Stats
        this.calculateExecutionSummary(analysis);
        
        // Step 5: Visual Representation
        this.visualizeExecutionChains(analysis);
        
        return analysis;
    }

    /**
     * Build execution chain for a page
     */
    private async buildPageExecutionChain(
        page: mgmtApi.PageItem, 
        entities: any, 
        assetUrlToIdMap: Map<string, number>
    ): Promise<ExecutionChain> {
        const chain: ExecutionChain = {
            entryPoint: createEntityKey('page', page.pageID),
            entryType: 'page',
            dependencies: [],
            isComplete: true,
            missingDependencies: [],
            depth: 0
        };

        const visited = new Set<EntityKey>();
        await this.buildExecutionDependencyTree(chain.entryPoint, entities, chain.dependencies, visited, 0, assetUrlToIdMap, chain);
        
        chain.depth = this.calculateMaxDepth(chain.dependencies);
        
        return chain;
    }

    /**
     * Build execution chain for content with nested dependencies
     */
    private async buildContentExecutionChain(
        content: mgmtApi.ContentItem, 
        entities: any, 
        assetUrlToIdMap: Map<string, number>
    ): Promise<ExecutionChain> {
        const chain: ExecutionChain = {
            entryPoint: createEntityKey('content', content.contentID),
            entryType: 'content',
            dependencies: [],
            isComplete: true,
            missingDependencies: [],
            depth: 0
        };

        const visited = new Set<EntityKey>();
        await this.buildExecutionDependencyTree(chain.entryPoint, entities, chain.dependencies, visited, 0, assetUrlToIdMap, chain);
        
        chain.depth = this.calculateMaxDepth(chain.dependencies);
        
        return chain;
    }

    /**
     * Build dependency tree for execution chain
     */
    private async buildExecutionDependencyTree(
        entityKey: EntityKey,
        entities: any,
        dependencies: DependencyNode[],
        visited: Set<EntityKey>,
        depth: number,
        assetUrlToIdMap: Map<string, number>,
        chain: ExecutionChain
    ): Promise<void> {
        if (visited.has(entityKey) || depth > 10) return;
        
        visited.add(entityKey);
        const { type, id } = parseEntityKey(entityKey);
        
        const entityData = this.findEntityData(type, id, entities);
        if (!entityData) {
            // Only log missing page templates - critical for pages
            if (type === 'template') {
                console.log(ansiColors.red(`🔴 Page template "${id}" referenced by ${chain.entryPoint} but not found in source data`));
            }
            chain.missingDependencies.push(`${type}:${id}`);
            chain.isComplete = false;
            return;
        }

        const entityDependencies = this.getExecutionDependencies(type, entityData, entities, assetUrlToIdMap);
        
        for (const dep of entityDependencies) {
            const depNode: DependencyNode = {
                entity: dep.targetEntity,
                relationship: dep.relationship,
                isRequired: dep.isRequired,
                fieldPath: dep.fieldPath,
                depth: depth + 1,
                children: []
            };
            
            dependencies.push(depNode);
            
            // Check if target entity exists
            const { type: targetType, id: targetId } = parseEntityKey(dep.targetEntity);
            const targetExists = this.findEntityData(targetType, targetId, entities);
            
            if (!targetExists) {
                // Only log missing page templates - critical for pages
                if (targetType === 'template') {
                    console.log(ansiColors.red(`🔴 Page template "${targetId}" referenced by ${type}:${id} but not found in source data`));
                }
                chain.missingDependencies.push(`${targetType}:${targetId}`);
                chain.isComplete = false;
            } else {
                // Recursively build dependencies
                await this.buildExecutionDependencyTree(dep.targetEntity, entities, depNode.children, visited, depth + 1, assetUrlToIdMap, chain);
            }
        }
    }

    /**
     * Get dependencies that matter for execution
     */
    private getExecutionDependencies(type: EntityType, entityData: any, entities: any, assetUrlToIdMap: Map<string, number>): EntityDependency[] {
        const allDeps = this.getEntityDependencies(type, entityData, entities, assetUrlToIdMap);
        
        // Include ALL meaningful dependencies for complete chain visualization:
        return allDeps.filter(dep => {
            // Include all dependency types for complete chain analysis:
            // - Templates (page → template)
            // - Content relationships (page → content, content → content)
            // - Models (content → model, container → model)
            // - Assets (content → asset)
            // - Containers (relationships involving containers)
            return dep.relationship === RelationshipType.TEMPLATE_TO_PAGE ||
                   dep.relationship === RelationshipType.CONTENT_TO_CONTENT ||
                   dep.relationship === RelationshipType.CONTENT_TO_PAGE ||
                   dep.relationship === RelationshipType.MODEL_TO_CONTENT ||
                   dep.relationship === RelationshipType.CONTAINER_TO_MODEL ||
                   dep.relationship === RelationshipType.CONTENT_TO_ASSET ||
                   dep.relationship === RelationshipType.PAGE_TO_PAGE ||
                   dep.relationship === RelationshipType.MODEL_TO_MODEL ||
                   dep.relationship === RelationshipType.GALLERY_TO_ASSET;
        });
    }

    /**
     * Mark all entities in a chain as processed
     */
    private markChainEntities(chain: ExecutionChain, processedEntities: Set<EntityKey>): void {
        processedEntities.add(chain.entryPoint);
        
        const markDeps = (deps: DependencyNode[]) => {
            for (const dep of deps) {
                processedEntities.add(dep.entity);
                markDeps(dep.children);
            }
        };
        
        markDeps(chain.dependencies);
    }

    /**
     * Identify standalone items that don't need complex dependency resolution
     */
    private identifyStandaloneItems(entities: any, processedEntities: Set<EntityKey>, analysis: ExecutionChainAnalysis): void {
        if (entities.content) {
            for (const content of entities.content) {
                const key = createEntityKey('content', content.contentID);
                if (!processedEntities.has(key)) {
                    analysis.standaloneItems.content.push(content);
                }
            }
        }

        if (entities.pages) {
            for (const page of entities.pages) {
                const key = createEntityKey('page', page.pageID);
                if (!processedEntities.has(key)) {
                    analysis.standaloneItems.pages.push(page);
                }
            }
        }
    }

    /**
     * Calculate execution summary
     */
    private calculateExecutionSummary(analysis: ExecutionChainAnalysis): void {
        analysis.summary.totalExecutableChains = analysis.completeChains.length;
        analysis.summary.totalBrokenChains = analysis.brokenChains.length;
        analysis.summary.totalStandaloneItems = analysis.standaloneItems.content.length + analysis.standaloneItems.pages.length;
        analysis.summary.parallelExecutionGroups = analysis.completeChains.length + 1; // +1 for standalone group
    }

    /**
     * Create visual representation of execution chains
     */
    private visualizeExecutionChains(analysis: ExecutionChainAnalysis): void {
        console.log(ansiColors.cyan('\n🔗 EXECUTION CHAIN ANALYSIS'));
        console.log(ansiColors.cyan('=' .repeat(50)));
        
        // Group chains by depth
        const chainsByDepth = new Map<number, number>();
        analysis.completeChains.forEach(chain => {
            const depth = Math.max(1, chain.depth); // Minimum depth of 1
            chainsByDepth.set(depth, (chainsByDepth.get(depth) || 0) + 1);
        });

        // Show chains by depth level
        console.log(ansiColors.yellow('\n📏 DEPENDENCY CHAINS BY DEPTH:'));
        const sortedDepths = Array.from(chainsByDepth.keys()).sort((a, b) => a - b);
        if (sortedDepths.length > 0) {
            sortedDepths.forEach(depth => {
                const count = chainsByDepth.get(depth) || 0;
                const levelDesc = depth === 1 ? 'level deep (simple references)' : `levels deep (nested dependencies)`;
                console.log(ansiColors.green(`  Found ${count} chains ${depth} ${levelDesc}`));
            });
        } else {
            console.log(ansiColors.gray('  No complex dependency chains found'));
        }

        // Separate chains by type
        const pageChains = analysis.completeChains.filter(chain => chain.entryType === 'page');
        const contentChains = analysis.completeChains.filter(chain => chain.entryType === 'content');

        // Show ALL page chains
        if (pageChains.length > 0) {
            console.log(ansiColors.yellow('\n📄 ALL PAGE CHAINS:'));
            pageChains.forEach((chain, index) => {
                const { type, id } = parseEntityKey(chain.entryPoint);
                console.log(ansiColors.green(`\n  Page Chain ${index + 1}: ${this.formatEntityDisplay(chain.entryPoint)} (${chain.dependencies.length} dependencies)`));
                
                if (chain.dependencies.length > 0) {
                    this.printDependencyTree(chain.dependencies, '    ');
                } else {
                    console.log(ansiColors.gray('    (no dependencies)'));
                }
            });
        }

        // Show sample content chains (first 3)
        if (contentChains.length > 0) {
            console.log(ansiColors.yellow('\n📋 CONTENT CHAINS (sample):'));
            const samplesToShow = Math.min(3, contentChains.length);
            for (let i = 0; i < samplesToShow; i++) {
                const chain = contentChains[i];
                console.log(ansiColors.green(`\n  Content Chain ${i + 1}: ${this.formatEntityDisplay(chain.entryPoint)} (${chain.dependencies.length} dependencies)`));
                
                if (chain.dependencies.length > 0) {
                    this.printDependencyTree(chain.dependencies, '    ');
                } else {
                    console.log(ansiColors.gray('    (no dependencies)'));
                }
            }
            
            if (contentChains.length > samplesToShow) {
                console.log(ansiColors.cyan(`    ... and ${contentChains.length - samplesToShow} more content chains`));
            }
        }

        // Show sample model-only chains (models that appear as entry points)
        console.log(ansiColors.yellow('\n📐 MODEL-ONLY CHAINS (sample):'));
        let modelChainCount = 0;
        const allChains = [...pageChains, ...contentChains];
        
        // Find chains that primarily involve models
        const modelCentricChains = allChains.filter(chain => {
            const modelDeps = this.countDependenciesByType(chain.dependencies);
            return modelDeps.models > 0 && (modelDeps.content === 0 || modelDeps.models >= modelDeps.content);
        }).slice(0, 3);

        if (modelCentricChains.length > 0) {
            modelCentricChains.forEach((chain, index) => {
                console.log(ansiColors.green(`\n  Model Chain ${index + 1}: ${this.formatEntityDisplay(chain.entryPoint)} (model-centric)`));
                this.printDependencyTree(chain.dependencies, '    ');
                modelChainCount++;
            });
        } else {
            console.log(ansiColors.gray('  No model-centric chains found (models are typically dependencies, not entry points)'));
        }

        // Show standalone items by type
        const standaloneContentCount = analysis.standaloneItems.content.length;
        const standalonePagesCount = analysis.standaloneItems.pages.length;
        const totalStandalone = standaloneContentCount + standalonePagesCount;
        
        if (totalStandalone > 0) {
            console.log(ansiColors.blue('\n🔗 STANDALONE ITEMS (no complex dependencies):'));
            if (standaloneContentCount > 0) {
                console.log(ansiColors.blue(`  Found ${standaloneContentCount} content items not in chains`));
            }
            if (standalonePagesCount > 0) {
                console.log(ansiColors.blue(`  Found ${standalonePagesCount} pages not in chains`));
            }
        }

        // Final execution strategy summary
        console.log(ansiColors.yellow('\n🎯 EXECUTION STRATEGY:'));
        console.log(ansiColors.cyan(`  ⚡ ${analysis.summary.totalExecutableChains} complete chains can execute in parallel`));
        console.log(ansiColors.cyan(`  ⚡ ${totalStandalone} standalone items can execute in parallel`));
        console.log(ansiColors.cyan(`  📊 Total parallel execution groups: ${analysis.summary.parallelExecutionGroups}`));
        
        if (analysis.summary.totalBrokenChains > 0) {
            console.log(ansiColors.red(`  ⚠️  ${analysis.summary.totalBrokenChains} chains need investigation before execution`));
        }
    }

    /**
     * Count dependencies by type in a dependency tree
     */
    private countDependenciesByType(dependencies: DependencyNode[]): { models: number; content: number; assets: number; templates: number; pages: number } {
        const counts = { models: 0, content: 0, assets: 0, templates: 0, pages: 0 };
        
        const countRecursive = (deps: DependencyNode[]) => {
            deps.forEach(dep => {
                const { type } = parseEntityKey(dep.entity);
                switch (type) {
                    case 'model': counts.models++; break;
                    case 'content': counts.content++; break;
                    case 'asset': counts.assets++; break;
                    case 'template': counts.templates++; break;
                    case 'page': counts.pages++; break;
                }
                countRecursive(dep.children);
            });
        };
        
        countRecursive(dependencies);
        return counts;
    }

    /**
     * Format entity display with proper field names
     */
    private formatEntityDisplay(entityKey: EntityKey): string {
        const { type, id } = parseEntityKey(entityKey);
        
        switch (type) {
            case 'asset':
                // Show MediaID instead of generic asset ID
                return `MediaID:${id}`;
            case 'content':
                return `ContentID:${id}`;
            case 'page':
                return `PageID:${id}`;
            case 'template':
                return `Template:${id}`;
            case 'model':
                return `Model:${id}`;
            case 'container':
                return `ContainerID:${id}`;
            case 'gallery':
                return `GalleryID:${id}`;
            default:
                return `${type}:${id}`;
        }
    }

    /**
     * Get color for relationship type
     */
    private getRelationshipColor(relationship: RelationshipType): (str: string) => string {
        switch (relationship) {
            case RelationshipType.TEMPLATE_TO_PAGE:
                return ansiColors.magenta; // Purple for templates
            case RelationshipType.CONTENT_TO_PAGE:
            case RelationshipType.CONTENT_TO_CONTENT:
                return ansiColors.blue; // Blue for content relationships
            case RelationshipType.MODEL_TO_CONTENT:
                return ansiColors.green; // Green for model relationships
            case RelationshipType.CONTENT_TO_ASSET:
                return ansiColors.yellow; // Yellow for asset relationships
            case RelationshipType.PAGE_TO_PAGE:
                return ansiColors.cyan; // Cyan for page relationships
            case RelationshipType.GALLERY_TO_ASSET:
                return ansiColors.gray; // Gray for gallery relationships
            default:
                return ansiColors.white; // White for other relationships
        }
    }

    /**
     * Print dependency tree in a readable format with color coding
     */
    private printDependencyTree(dependencies: DependencyNode[], indent: string): void {
        for (const dep of dependencies) {
            // All entities get green circles - no more yellow/red confusion
            const statusIcon = '🟢';
            const colorFn = this.getRelationshipColor(dep.relationship);
            const entityDisplay = this.formatEntityDisplay(dep.entity);
            
            console.log(`${indent}${statusIcon} ${colorFn(entityDisplay)} ${ansiColors.gray(`(${dep.relationship})`)}`);
            if (dep.children.length > 0) {
                this.printDependencyTree(dep.children, indent + '  ');
            }
        }
    }

    /**
     * Show non-chained items by entity type (from dependency chain analysis)
     */
    showNonChainedItemsByType(chainAnalysis: DependencyChainAnalysis): void {
        console.log(ansiColors.blue('\n🔗 NON-CHAINED ITEMS BY TYPE:'));
        
        const nonChainedCounts = chainAnalysis.entityCounts.nonDependent;
        const entityTypes = ['models', 'containers', 'content', 'templates', 'pages', 'assets'] as const;
        const icons = ['📐', '📦', '📄', '📋', '📃', '🖼️'];
        
        entityTypes.forEach((entityType, index) => {
            const count = nonChainedCounts[entityType];
            if (count > 0) {
                console.log(ansiColors.blue(`  ${icons[index]} Found ${count} ${entityType} not in chains`));
            }
        });
    }

    /**
     * Create asset URL mapping
     */
    private createAssetUrlMapping(assets: mgmtApi.Media[]): Map<string, number> {
        const map = new Map<string, number>();
        assets.forEach(asset => {
            if (asset.originUrl) {
                const normalizedUrl = this.normalizeAssetUrl(asset.originUrl);
                map.set(normalizedUrl, asset.mediaID);
                if (normalizedUrl !== asset.originUrl) {
                    map.set(asset.originUrl, asset.mediaID);
                }
            }
        });
        return map;
    }
} 