        console.log(`   ✅ Created ${entities.content.length} content items`);
        console.log(`   ✅ Created ${entities.containers.length} containers`);
        console.log(`   ✅ Created ${entities.templates.length} templates`);
        console.log(`   ✅ Created ${entities.pages.length} pages`);

        return entities;
    }

    /**
     * Create mock analysis results for upload sequence converter
     */
    private createMockAnalysisResults(entities: TestEntitySet): ChainAnalysisResults {
        // Flatten entities for analysis
        const allEntities = [
            ...entities.models.map(m => ({ type: 'Model', id: m.id, data: m })),
            ...entities.galleries.map(g => ({ type: 'Gallery', id: g.assetMediaGroupings[0].mediaGroupingID, data: g })),
            ...entities.assets.map(a => ({ type: 'Asset', id: a.mediaID, data: a })),
            ...entities.content.map(c => ({ type: 'Content', id: c.contentID, data: c })),
            ...entities.containers.map(c => ({ type: 'Container', id: c.contentViewID, data: c })),
            ...entities.templates.map(t => ({ type: 'Template', id: t.pageTemplateID, data: t })),
            ...entities.pages.map(p => ({ type: 'Page', id: p.pageID, data: p }))
        ];

        return {
            chainResults: [{
                chain: allEntities,
                type: 'page',
                startingEntity: entities.pages[0],
                dependencies: this.extractDependencies(entities),
                success: true
            }],
            nonChainedItems: {
                models: [],
                content: [],
                assets: [],
                templates: [],
                pages: [],
                galleries: []
            },
            brokenChains: [],
            totalInChains: allEntities.length,
            totalNonChained: 0,
            reconciliation: {
                totalEntities: allEntities.length,
                entitiesInChains: allEntities.length,
                entitiesOutOfChains: 0,
                syncableEntities: allEntities.length
            }
        };
    }

    /**
     * Extract dependencies following data-relationships.md patterns
     */
    private extractDependencies(entities: TestEntitySet): any[] {
        const dependencies = [];

        // Page → Template dependencies
        entities.pages.forEach(page => {
            const template = entities.templates.find(t => t.pageTemplateName === page.templateName);
            if (template) {
                dependencies.push({
                    dependent: `Page:${page.pageID}`,
                    dependency: `Template:${template.pageTemplateID}`,
                    type: 'page-template'
                });
            }

            // Page → Content dependencies (via zones)
            Object.values(page.zones || {}).flat().forEach((zoneItem: any) => {
                if (zoneItem.item?.contentid) {
                    dependencies.push({
                        dependent: `Page:${page.pageID}`,
                        dependency: `Content:${zoneItem.item.contentid}`,
                        type: 'page-content'
                    });
                }
            });
        });

        // Template → Container dependencies
        entities.templates.forEach(template => {
            template.contentSectionDefinitions?.forEach((section: any) => {
                if (section.itemContainerID) {
                    dependencies.push({
                        dependent: `Template:${template.pageTemplateID}`,
                        dependency: `Container:${section.itemContainerID}`,
                        type: 'template-container'
                    });
                }
            });
        });

        // Container → Model dependencies
        entities.containers.forEach(container => {
            dependencies.push({
                dependent: `Container:${container.contentViewID}`,
                dependency: `Model:${container.contentDefinitionID}`,
                type: 'container-model'
            });
        });

        // Content → Asset dependencies
        entities.content.forEach(content => {
            Object.values(content.fields || {}).forEach((field: any) => {
                if (field?.url && field?.mediaID) {
                    dependencies.push({
                        dependent: `Content:${content.contentID}`,
                        dependency: `Asset:${field.mediaID}`,
                        type: 'content-asset'
                    });
                }
            });

            // Content → Content dependencies
            Object.values(content.fields || {}).forEach((field: any) => {
                if (field?.contentid) {
                    dependencies.push({
                        dependent: `Content:${content.contentID}`,
                        dependency: `Content:${field.contentid}`,
                        type: 'content-content'
                    });
                }
            });
        });

        // Asset → Gallery dependencies
        entities.assets.forEach(asset => {
            if (asset.mediaGroupingID) {
                dependencies.push({
                    dependent: `Asset:${asset.mediaID}`,
                    dependency: `Gallery:${asset.mediaGroupingID}`,
                    type: 'asset-gallery'
                });
            }
        });

        return dependencies;
    }

    /**
     * Validate dependency ordering matches data-relationships.md
     */
    private validateDependencyOrdering(uploadSequence: OptimizedUploadSequence): void {
        console.log('\n🔍 Validating Dependency Ordering...');

        const expectedOrder = ['Gallery', 'Asset', 'Model', 'Content', 'Container', 'Template', 'Page'];
        const actualOrder: string[] = [];

        uploadSequence.batches.forEach(batch => {
            batch.entities.forEach(entity => {
                if (!actualOrder.includes(entity.type)) {
                    actualOrder.push(entity.type);
                }
            });
        });

        console.log(`   Expected order: ${expectedOrder.join(' → ')}`);
        console.log(`   Actual order:   ${actualOrder.join(' → ')}`);

        // Validate critical dependencies
        const galleryIndex = actualOrder.indexOf('Gallery');
        const assetIndex = actualOrder.indexOf('Asset');
        const modelIndex = actualOrder.indexOf('Model');
        const contentIndex = actualOrder.indexOf('Content');
        const containerIndex = actualOrder.indexOf('Container');
        const templateIndex = actualOrder.indexOf('Template');
        const pageIndex = actualOrder.indexOf('Page');

        if (galleryIndex > assetIndex) {
            throw new Error('Dependency violation: Galleries must come before Assets');
        }
        if (assetIndex > contentIndex) {
            throw new Error('Dependency violation: Assets must come before Content');
        }
        if (modelIndex > containerIndex) {
            throw new Error('Dependency violation: Models must come before Containers');
        }
        if (containerIndex > templateIndex) {
            throw new Error('Dependency violation: Containers must come before Templates');
        }
        if (templateIndex > pageIndex) {
            throw new Error('Dependency violation: Templates must come before Pages');
        }

        console.log('   ✅ Dependency ordering validated');
    }

    /**
     * Initialize orchestrator with test configuration
     */
    private initializeOrchestrator(): void {
        console.log('\n🎯 Initializing Topological Two-Pass Orchestrator...');

        const config: TopologicalTwoPassConfig = {
            apiOptions: this.apiOptions,
            targetGuid: this.targetGuid,
            locale: this.locale,
            referenceMapper: this.referenceMapper,
            onProgress: (level: number, pass: 1 | 2, entityType: string, processed: number, total: number, status?: 'success' | 'error') => {
                const statusIcon = status === 'error' ? '❌' : '✅';
                const passDesc = pass === 1 ? 'Stub Creation' : 'Full Population';
                console.log(`    ${statusIcon} Level ${level} ${passDesc} - ${entityType}: ${processed}/${total}`);
            }
        };

        this.orchestrator = new TopologicalTwoPassOrchestrator(config);
        console.log('   ✅ Orchestrator initialized');
    }

    /**
     * Execute mock 2-pass upload (simulates without actual API calls)
     */
    private async executeMockTwoPassUpload(uploadSequence: OptimizedUploadSequence): Promise<void> {
        console.log('\n🔄 Executing Mock Two-Pass Upload...');

        // Mock Pass 1: Create entity stubs and add to reference mapper
        console.log('\n🔧 PASS 1: Creating Entity Stubs...');
        
        uploadSequence.batches.forEach((batch, batchIndex) => {
            console.log(`   Batch ${batchIndex} (Level ${batch.level}):`);
            
            batch.entities.forEach(entity => {
                // Mock creating stub and getting target ID
                const targetId = this.generateMockTargetId(entity.type, entity.id);
                const targetEntity = { ...entity.data, id: targetId };

                // Add to reference mapper
                this.referenceMapper.addMapping(entity.type.toLowerCase() as any, entity.data, targetEntity);
                
                console.log(`     ✅ Created ${entity.type} stub: ${entity.id} → ${targetId}`);
            });
        });

        // Mock Pass 2: Update with full data using target IDs
        console.log('\n🔧 PASS 2: Populating Full Data...');
        
        uploadSequence.batches.forEach((batch, batchIndex) => {
            console.log(`   Batch ${batchIndex} (Level ${batch.level}):`);
            
            batch.entities.forEach(entity => {
                // Mock updating with relationships using target IDs
                const mapping = this.referenceMapper.getMapping(entity.type.toLowerCase() as any, entity.id);
                if (mapping?.target) {
                    console.log(`     ✅ Updated ${entity.type} with relationships: ${entity.id} → ${mapping.target.id}`);
                }
            });
        });
    }

    /**
     * Generate mock target ID for testing
     */
    private generateMockTargetId(entityType: string, sourceId: number): number {
        // Simple mock: add 10000 to source ID to simulate target ID
        return sourceId + 10000;
    }

    /**
     * Validate final relationships are correctly mapped
     */
    private validateFinalRelationships(): void {
        console.log('\n🔍 Validating Final Relationships...');

        // Check all entity types have mappings
        const stats = this.referenceMapper.getStats();
        console.log('   Reference Mapper Statistics:');
        
        Object.entries(stats).forEach(([type, stat]) => {
            console.log(`     ${type}: ${stat.withTargets}/${stat.total} mapped`);
            if (stat.withTargets !== stat.total) {
                throw new Error(`Missing mappings for ${type}: ${stat.total - stat.withTargets} unmapped`);
            }
        });

        // Validate specific relationships
        this.validatePageTemplateRelationship();
        this.validatePageContentRelationship();
        this.validateContentAssetRelationship();
        this.validateAssetGalleryRelationship();

        console.log('   ✅ All relationships validated');
    }

    /**
     * Validate page → template relationship
     */
    private validatePageTemplateRelationship(): void {
        const pageMapping = this.referenceMapper.getMapping('page', 7001);
        const templateMapping = this.referenceMapper.getMapping('template', 6001);

        if (!pageMapping?.target || !templateMapping?.target) {
            throw new Error('Page or Template mapping missing');
        }

        console.log(`     ✅ Page 7001 → Template 6001 (target: ${templateMapping.target.id})`);
    }

    /**
     * Validate page → content relationship (via zones)
     */
    private validatePageContentRelationship(): void {
        const contentMapping1 = this.referenceMapper.getMapping('content', 4001);
        const contentMapping2 = this.referenceMapper.getMapping('content', 4002);
        const contentMapping3 = this.referenceMapper.getMapping('content', 4003);

        if (!contentMapping1?.target || !contentMapping2?.target || !contentMapping3?.target) {
            throw new Error('Content mappings missing');
        }

        console.log(`     ✅ Page zones reference Content 4001 (target: ${contentMapping1.target.id}), 4002 (target: ${contentMapping2.target.id}), 4003 (target: ${contentMapping3.target.id})`);
    }

    /**
     * Validate content → asset relationship
     */
    private validateContentAssetRelationship(): void {
        const assetMapping1 = this.referenceMapper.getMapping('asset', 3001);
        const assetMapping2 = this.referenceMapper.getMapping('asset', 3002);

        if (!assetMapping1?.target || !assetMapping2?.target) {
            throw new Error('Asset mappings missing');
        }

        console.log(`     ✅ Content references Assets 3001 (target: ${assetMapping1.target.id}), 3002 (target: ${assetMapping2.target.id})`);
    }

    /**
     * Validate asset → gallery relationship
     */
    private validateAssetGalleryRelationship(): void {
        const galleryMapping = this.referenceMapper.getMapping('gallery', 2001);

        if (!galleryMapping?.target) {
            throw new Error('Gallery mapping missing');
        }

        console.log(`     ✅ Assets reference Gallery 2001 (target: ${galleryMapping.target.id})`);
    }
}

// Export for use in test runner
export async function runComprehensivePageCreationTest(targetGuid: string = 'test-target', locale: string = 'en-us'): Promise<void> {
    const test = new ComprehensivePageCreationTest(targetGuid, locale);
    await test.runComprehensiveTest();
}

// Direct execution for testing
if (require.main === module) {
    runComprehensivePageCreationTest('test-target', 'en-us')
        .then(() => {
            console.log('\n🎉 Test completed successfully!');
            process.exit(0);
        })
        .catch((error) => {
            console.error('\n❌ Test failed:', error);
            process.exit(1);
        });
} 