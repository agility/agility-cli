/**
 * Comprehensive Page Creation Test
 * 
 * Tests the complete 2-pass dependency chain by creating:
 * - Gallery with Assets
 * - Model for content structure  
 * - Content Items referencing assets
 * - Containers using the model
 * - Template with maincontentzone and sidebarzone
 * - Page using template and populating zones
 * 
 * Validates data-relationships.md understanding and 2-pass orchestration
 */

import * as mgmtApi from '@agility/management-sdk';
import { TopologicalTwoPassOrchestrator, TopologicalTwoPassConfig } from '../lib/services/topological-two-pass-orchestrator';
import { CoreReferenceMapper } from '../lib/core-reference-mapper';
import { UploadSequenceConverter, OptimizedUploadSequence } from '../lib/services/upload-sequence-converter';
import { ChainAnalysisResults } from '../lib/services/chain-builder';

interface TestEntitySet {
    models: any[];
    galleries: any[];
    assets: any[];
    content: any[];
    containers: any[];
    templates: any[];
    pages: any[];
}

export class ComprehensivePageCreationTest {
    private targetGuid: string;
    private locale: string;
    private apiOptions: mgmtApi.Options;
    private orchestrator: TopologicalTwoPassOrchestrator;
    private referenceMapper: CoreReferenceMapper;
    private sequenceConverter: UploadSequenceConverter;

    constructor(targetGuid: string, locale: string = 'en-us') {
        this.targetGuid = targetGuid;
        this.locale = locale;
        
        // Mock API options for testing
        this.apiOptions = {
            token: process.env.AGILITY_API_KEY || 'test-token',
            baseUrl: 'https://mgmt.aglty.io',
            refresh_token: '',
            duration: 30,
            retryCount: 3
        };

        this.referenceMapper = new CoreReferenceMapper('test-source', targetGuid);
        this.sequenceConverter = new UploadSequenceConverter();
    }

    /**
     * Main test execution method
     */
    async runComprehensiveTest(): Promise<void> {
        console.log('🧪 Starting Comprehensive Page Creation Test');
        console.log('=' .repeat(60));

        try {
            // Step 1: Create test entity set following data-relationships.md
            const testEntities = this.createTestEntitySet();
            
            // Step 2: Convert to upload sequence
            const analysisResults = this.createMockAnalysisResults(testEntities);
            const uploadSequence = this.sequenceConverter.convertToUploadSequence(analysisResults, { entities: testEntities });

            // Step 3: Validate dependency ordering
            this.validateDependencyOrdering(uploadSequence);

            // Step 4: Initialize orchestrator
            this.initializeOrchestrator();

            // Step 5: Execute 2-pass upload (MOCK MODE)
            await this.executeMockTwoPassUpload(uploadSequence);

            // Step 6: Validate final relationships
            this.validateFinalRelationships();

            console.log('🎉 Comprehensive Page Creation Test PASSED!');

        } catch (error: any) {
            console.error('❌ Comprehensive Page Creation Test FAILED:', error.message);
            throw error;
        }
    }

    /**
     * Create test entity set following data-relationships.md patterns
     */
    private createTestEntitySet(): TestEntitySet {
        console.log('\n📋 Creating Test Entity Set...');

        // 1. Model for Article content structure
        const articleModel = {
            id: 1001,
            referenceName: 'TestArticle',
            displayName: 'Test Article',
            contentDefinitionTypeID: 0, // Module
            fields: [
                {
                    name: 'title',
                    type: 'Text',
                    settings: {}
                },
                {
                    name: 'content',
                    type: 'HTML',
                    settings: {}
                },
                {
                    name: 'featuredImage',
                    type: 'ImageAttachment',
                    settings: {}
                },
                {
                    name: 'relatedArticle',
                    type: 'Content',
                    settings: {
                        ContentDefinition: 'TestArticle' // Model-to-Model reference
                    }
                }
            ]
        };

        // 2. Sidebar Navigation Model
        const sidebarModel = {
            id: 1002,
            referenceName: 'SidebarNavigation',
            displayName: 'Sidebar Navigation',
            contentDefinitionTypeID: 0,
            fields: [
                {
                    name: 'title',
                    type: 'Text',
                    settings: {}
                },
                {
                    name: 'links',
                    type: 'HTML',
                    settings: {}
                }
            ]
        };

        // 3. Gallery for test assets
        const testGallery = {
            assetMediaGroupings: [{
                mediaGroupingID: 2001,
                name: 'Test Gallery',
                desc: 'Gallery for comprehensive test assets'
            }]
        };

        // 4. Assets for the gallery
        const heroAsset = {
            mediaID: 3001,
            fileName: 'hero-image.jpg',
            originUrl: 'https://cdn.aglty.io/test/hero-image.jpg',
            url: 'https://cdn.aglty.io/test/hero-image.jpg',
            edgeUrl: 'https://cdn.aglty.io/test/hero-image.jpg',
            mediaGroupingID: 2001 // References gallery
        };

        const logoAsset = {
            mediaID: 3002,
            fileName: 'company-logo.png',
            originUrl: 'https://cdn.aglty.io/test/company-logo.png',
            url: 'https://cdn.aglty.io/test/company-logo.png',
            edgeUrl: 'https://cdn.aglty.io/test/company-logo.png',
            mediaGroupingID: 2001 // References gallery
        };

        // 5. Content Items
        const mainArticleContent = {
            contentID: 4001,
            properties: {
                definitionName: 'TestArticle', // References Model.referenceName
                referenceName: 'main-article-container' // References Container.referenceName
            },
            fields: {
                title: 'Comprehensive Test Article',
                content: '<p>This is a test article with dependencies.</p>',
                featuredImage: {
                    url: 'https://cdn.aglty.io/test/hero-image.jpg', // References Asset
                    mediaID: 3001
                },
                relatedArticle: {
                    contentid: 4002 // Content-to-Content reference (lowercase)
                }
            }
        };

        const relatedArticleContent = {
            contentID: 4002,
            properties: {
                definitionName: 'TestArticle',
                referenceName: 'related-article-container'
            },
            fields: {
                title: 'Related Test Article',
                content: '<p>This is a related article.</p>',
                featuredImage: {
                    url: 'https://cdn.aglty.io/test/company-logo.png', // References Asset
                    mediaID: 3002
                }
            }
        };

        const sidebarContent = {
            contentID: 4003,
            properties: {
                definitionName: 'SidebarNavigation',
                referenceName: 'sidebar-navigation-container'
            },
            fields: {
                title: 'Navigation',
                links: '<ul><li><a href="/home">Home</a></li><li><a href="/about">About</a></li></ul>'
            }
        };

        // 6. Containers
        const mainArticleContainer = {
            contentViewID: 5001,
            contentDefinitionID: 1001, // References Model.id
            referenceName: 'main-article-container',
            contentViewName: 'Main Article Container'
        };

        const relatedArticleContainer = {
            contentViewID: 5002,
            contentDefinitionID: 1001, // References Model.id
            referenceName: 'related-article-container',
            contentViewName: 'Related Article Container'
        };

        const sidebarContainer = {
            contentViewID: 5003,
            contentDefinitionID: 1002, // References Model.id
            referenceName: 'sidebar-navigation-container',
            contentViewName: 'Sidebar Navigation Container'
        };

        // 7. Template with maincontentzone and sidebarzone
        const testTemplate = {
            pageTemplateID: 6001,
            pageTemplateName: 'TestPageTemplate',
            zones: ['maincontentzone', 'sidebarzone'],
            contentSectionDefinitions: [
                {
                    contentDefinitionID: 1001, // References Model.id for articles
                    itemContainerID: 5001      // References Container.contentViewID
                },
                {
                    contentDefinitionID: 1002, // References Model.id for sidebar
                    itemContainerID: 5003      // References Container.contentViewID
                }
            ]
        };

        // 8. Page using template and populating zones
        const testPage = {
            pageID: 7001,
            name: 'Test Page',
            templateName: 'TestPageTemplate', // References Template.pageTemplateName
            parentPageID: null, // Root page
            zones: {
                maincontentzone: [
                    {
                        item: {
                            contentid: 4001 // References Content.contentID (lowercase)
                        }
                    },
                    {
                        item: {
                            contentid: 4002 // References Content.contentID (lowercase)
                        }
                    }
                ],
                sidebarzone: [
                    {
                        item: {
                            contentid: 4003 // References Content.contentID (lowercase)
                        }
                    }
                ]
            }
        };

        const entities: TestEntitySet = {
            models: [articleModel, sidebarModel],
            galleries: [testGallery],
            assets: [heroAsset, logoAsset],
            content: [mainArticleContent, relatedArticleContent, sidebarContent],
            containers: [mainArticleContainer, relatedArticleContainer, sidebarContainer],
            templates: [testTemplate],
