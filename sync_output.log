les - Azure app.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Enter the connection string and access key values obtained from Azure Blob Storage in the Azure Portal.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Save the configuration to enable the app.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Add the Secure File custom field to a Content or Component Model.\\u0022,\\u0022items\\u0022:[]}]}},{\\u0022id\\u0022:\\u0022jxmUKXpIZU\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Code Example\\u0022,\\u0022level\\u0022:3}},{\\u0022id\\u0022:\\u0022eCNjum80az\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022To deliver files to the frontend using a pre-signed SAS URL, you can use the following code snippet:\\u0022}},{\\u0022id\\u0022:\\u0022Toc3RYUU1u\\u0022,\\u0022type\\u0022:\\u0022code\\u0022,\\u0022data\\u0022:{\\u0022code\\u0022:\\u0022const { BlobServiceClient, generateBlobSASQueryParameters, StorageSharedKeyCredential } = require(\\u0027@azure/storage-blob\\u0027);\\\\n\\\\n// Azure Storage account details\\\\nconst accountName = \\u0027your_account_name\\u0027;\\\\nconst accountKey = \\u0027your_account_key\\u0027;\\\\nconst containerName = \\u0027your_container_name\\u0027;\\\\n\\\\n//get the blob name from your agility content item\\\\nconst blobName = \\u0027your_blob_name\\u0027; \\\\n\\\\n// Create a shared key credential\\\\nconst sharedKeyCredential = new StorageSharedKeyCredential(accountName, accountKey);\\\\n\\\\n// Create a SAS token\\\\nconst sasToken = generateBlobSASQueryParameters({\\\\n  containerName,\\\\n  blobName,\\\\n  permissions: \\u0027r\\u0027, // Read permission\\\\n  startsOn: new Date(),\\\\n  expiresOn: new Date(new Date().valueOf() \\u002B 3600 * 1000) // 1 hour expiry\\\\n}, sharedKeyCredential).toString();\\\\n\\\\n// Construct the SAS URL\\\\nconst sasUrl = \\u0060https://${accountName}.blob.core.windows.net/${containerName}/${blobName}?${sasToken}\\u0060;\\\\n\\\\nconsole.log(\\u0027SAS URL:\\u0027, sasUrl);\\\\n\\\\n// Use the SAS URL to deliver the file to the frontend\\\\n// Example: \\u003Ca href={sasUrl} download\\u003EDownload File\\u003C/a\\u003E\\\\n\\u0022}},{\\u0022id\\u0022:\\u0022UwfOsTCPsi\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022This code generates a pre-signed SAS URL that allows secure access to a specific blob for a limited time. You can use this URL in your frontend to enable users to download files securely.\\u0022}}]}","section":{"contentid":858,"fulllist":false},"section_TextField":"Marketplace Apps","section_ValueField":"858","concept":{"contentid":859,"fulllist":false},"concept_TextField":"Apps","concept_ValueField":"859"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"appsarticles","definitionName":"DocArticle","itemOrder":18},"fields":{"title":"Secure Files - AWS","slug":"secure-files-aws","description":"Use secure files from AWS S3 in your website or apps with Agility content.","content":"{\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u0022FNAL1LCAnD\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Secure File Storage App for Agility CMS using AWS S3\\u0022,\\u0022level\\u0022:3}},{\\u0022id\\u0022:\\u0022dE5LdxD7nV\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Description:\\u0026nbsp;This app enables you to securely store and manage files in Agility CMS using AWS S3. By integrating AWS S3, you can leverage its robust security features and scalability to handle your file storage needs efficiently.\\u0022}},{\\u0022id\\u0022:\\u0022qv3VU4k6tb\\u0