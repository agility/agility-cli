ttom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"editorarticles","definitionName":"DocArticle","itemOrder":8},"fields":{"title":"Scheduling Overview","slug":"scheduling","description":"Schedule time-sensitive content releases with ease.","content":"{\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u0022AKgYcF1pbr\\u0022,\\u0022type\\u0022:\\u0022raw\\u0022,\\u0022data\\u0022:{\\u0022html\\u0022:\\u0022\\u003Cdiv style=\\\\\\u0022padding:56.25% 0 0 0;position:relative;\\\\\\u0022\\u003E\\u003Ciframe src=\\\\\\u0022https://player.vimeo.com/video/1056772017?h=140ba142c1\\u0026amp;badge=0\\u0026amp;autopause=0\\u0026amp;player_id=0\\u0026amp;app_id=58479\\\\\\u0022 frameborder=\\\\\\u00220\\\\\\u0022 allow=\\\\\\u0022autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media\\\\\\u0022 style=\\\\\\u0022position:absolute;top:0;left:0;width:100%;height:100%;\\\\\\u0022 title=\\\\\\u0022How-to Series | Scheduling Items and Pages\\\\\\u0022\\u003E\\u003C/iframe\\u003E\\u003C/div\\u003E\\u003Cscript src=\\\\\\u0022https://player.vimeo.com/api/player.js\\\\\\u0022\\u003E\\u003C/script\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022hgfGRcSpaq\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022What is Scheduling and why is it important?\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022cO6V-MNKED\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Agility offers powerful publication scheduling that allows you to plan your content in advance and decide a specific \\u003Cb\\u003ERelease Date\\u003C/b\\u003E \\u003Ci\\u003E(when your content should automatically be published)\\u003C/i\\u003E or an \\u003Cb\\u003EExpiry Date\\u003C/b\\u003E \\u003Ci\\u003E(when your content should automatically be unpublished)\\u0026nbsp;\\u003C/i\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022LVOKwMP45a\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022What can be Scheduled?\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u00228p8aAlX3ML\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Within Agility you can schedule:\\u0026nbsp;\\u0026nbsp;\\u0022}},{\\u0022id\\u0022:\\u0022c4NT8VAGNC\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022unordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022Content Items\\u0026nbsp;\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Pages\\u0026nbsp;\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Components\\u0026nbsp;\\u0022,\\u0022items\\u0022:[]}]}},{\\u0022id\\u0022:\\u00223bnmudpaKc\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Scheduling a Release or Expiry Date\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022KGhwd0tHyN\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022What is a Release Date?\\u0022,\\u0022level\\u0022:3}},{\\u0022id\\u0022:\\u0022D9FgVhbOK1\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022The \\u003Cb\\u003ERelease Date\\u003C/b\\u003E is the time and date you want the content to automatically \\u003Cb\\u003EPublish\\u003C/b\\u003E itself to your live site. This can be done for either a brand-new page or piece of content that has not been previously published to your site or to schedule an update to an existing page or piece of content.\\u0026nbsp;\\u0022}},{\\u0022id\\u0022:\\u0022TBsONLbmtH\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022In the event you\\u2019re scheduling an update to an existing page or piece of content and do not want the old version to remain live in the meantime, be sure to unpublish it first.\\u0026nbsp;\\u0022}},{\\u0022id\\u0022:\\u0022svaK68IHKP\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022How to Set a Release Date\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022M4Gyib-rVz\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u00221. While in Edit mode for the Layout, Component or Piece of Content you\\u2019re managing, click the \\u003Cb\\u003EMenu Icon\\u003C/b\\u003E on the right-hand side.\\u003Cbr\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022LVsEt0f0DF\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u00222. Select \\u003Cb\\u003ESchedule\\u003C/b\\u003E.\\u0022}},{\\u0022id\\u0022:\\u0022LA6-f_lLY0\\u0022,\\u0022type\\u0022:\\u0022image\\u0022,\\u0022data\\u0022:{\\u0022file\\u0022:{\\u0022url\\u0022:\\u0022https://cdn.aglty.io/agility-cms-docs/images/block-editor/Refresh - Schedule Dropdown-02232024165706.png\\u0022,\\u0022size\\u0022:{\\u0022height\\u0022:1055,\\u0022width\\u0022:1850,\\u0022type\\u0022:\\u0022png\\u0022}},\\u0022caption\\u0022:\\u0022Screenshot showing where to select the schedule option\\u003Cbr\\u003E\\u0022,\\u0022withBorder\\u0022:false,\\u0022stretched\\u0022:false,\\u0022withBackground\\u0022:false}},{\\u0022id\\u0022:\\u0022jbPoN4YVmQ\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u00223. Click \\u003Cb\\u003ECreate a New Schedule \\u003C/b\\u003Efrom the slide-out on the right-hand side.\\u0022}},{\\u0022id\\u0022:\\u0022M5mob0mdhi\\u0022,\\u0022type\\u0022:\\u0022image\\u0022,\\u0022data\\u0022:{\\u0022file\\u0022:{\\u0022url\\u0022:\\u0022https://cdn.aglty.io/agility-cms-docs/images/block-editor/Refresh - Schedule Slide Out-02232024165816.png\\u0022,\\u0022size\\u0022:{\\u0022height\\u0022:1055,\\u0022width\\u0022:1850,\\u0022type\\u0022:\\u0022png\\u0022}},\\u0022caption\\u0022:\\u0022Schedule Slide-out\\u003Cbr\\u003E\\u0022,\\u0022withBorder\\u0022:false,\\u0022stretched\\u0022:false,\\u0022withBackground\\u0022:false}},{\\u0022id\\u0022:\\u00226cb7lZiPKL\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u00224. Set the \\u003Cb\\u003EDate and Time\\u003C/b\\u003E you\\u2019d like to schedule it to release and/or expire.\\u003Cbr\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022eW9n02zISl\\u0022,\\u0022type\\u0022:\\u0022image\\u0022,\\u0022data\\u0022:{\\u0022file\\u0022:{\\u0022url\\u0022:\\u0022https://cdn.aglty.io/agility-cms-docs/images/block-editor/Refresh - Schedule Date Picker-02232024165945.png\\u0022,\\u0022size\\u0022:{\\u0022height\\u0022:1055,\\u0022width\\u0022:1850,\\u0022type\\u0022:\\u0022png\\u0022}},\\u0022caption\\u0022:\\u0022Schedule date picker\\u003Cbr\\u003E\\u0022,\\u0022withBorder\\u0022:false,\\u0022stretched\\u0022:false,\\u0022withBackground\\u0022:false}},{\\u0022id\\u0022:\\u0022Tce5A-RE7l\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u00225. Click \\u003Cb\\u003ESchedule\\u0026nbsp;\\u003C/b\\u003E\\u0022}},{\\u0022id\\u0022:\\u002298bv5xDmoH\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Additionally, when clicking Publish for a Page or Piece of content you\\u2019ll receive a pop-up asking you to confirm you\\u2019d like to Publish and an option to schedule instead. By checking Schedule this item to be published you\\u2019ll be given the same options you\\u2019d see in the Scheduling Menu mentioned above.\\u0026nbsp;\\u0022}},{\\u0022id\\u0022:\\u0022qoDpXaPZnz\\u0022,\\u0022type\\u0022:\\u0022image\\u0022,\\u0022data\\u0022:{\\u0022file\\u0022:{\\u0022url\\u0022:\\u0022https://cdn.aglty.io/agility-cms-docs/images/block-editor/Screenshot 2024-02-23 at 1.00.48 PM-02232024170109.png\\u0022,\\u0022size\\u0022:{\\u0022height\\u0022:246,\\u0022width\\u0022:592,\\u0022type\\u0022:\\u0022png\\u0022}},\\u0022caption\\u0022:\\u0022Publish Confirmation Pop-up\\u003Cbr\\u003E\\u0022,\\u