  additionalData: '{"LanguageCode":"en-us","Items":[{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"dotnet_blockeditor152","definitionName":"BlockEditor","itemOrder":0},"fields":{"content":"{\\u0022time\\u0022:1632417727844,\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u00220SJ6Pe27YG\\u0022,\\u0022type\\u0022:\\u0022image\\u0022,\\u0022data\\u0022:{\\u0022file\\u0022:{\\u0022url\\u0022:\\u0022https://cdn.aglty.io/agility-cms-docs/block-editor/dotnet_blockeditor152/cdnlogo.com_c-09232021172204.svg\\u0022,\\u0022size\\u0022:{\\u0022height\\u0022:2500,\\u0022width\\u0022:2500,\\u0022type\\u0022:\\u0022svg\\u0022}},\\u0022caption\\u0022:\\u0022\\u0022,\\u0022withBorder\\u0022:false,\\u0022stretched\\u0022:false,\\u0022withBackground\\u0022:false}}],\\u0022version\\u0022:\\u00222.22.2\\u0022}"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"ownersadminsarticles","definitionName":"DocArticle","itemOrder":2},"fields":{"title":"About Instances","slug":"about-instances","description":"Your Organization includes one or many instances of Agility.","content":"{\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u0022dSdwCSMIrA\\u0022,\\u0022type\\u0022:\\u0022raw\\u0022,\\u0022data\\u0022:{\\u0022html\\u0022:\\u0022\\u003Cdiv style=\\\\\\u0022padding:56.25% 0 0 0;position:relative;\\\\\\u0022\\u003E\\u003Ciframe src=\\\\\\u0022https://player.vimeo.com/video/1055671999?h=f25028c0b4\\u0026amp;badge=0\\u0026amp;autopause=0\\u0026amp;player_id=0\\u0026amp;app_id=58479\\\\\\u0022 frameborder=\\\\\\u00220\\\\\\u0022 allow=\\\\\\u0022autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media\\\\\\u0022 style=\\\\\\u0022position:absolute;top:0;left:0;width:100%;height:100%;\\\\\\u0022 title=\\\\\\u0022Agility Foundations - Guided Walkthrough: Navigating Admin Tools\\\\\\u0022\\u003E\\u003C/iframe\\u003E\\u003C/div\\u003E\\u003Cscript src=\\\\\\u0022https://player.vimeo.com/api/player.js\\\\\\u0022\\u003E\\u003C/script\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022U5xNMxcaDY\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022An instance represents a dedicated area where your Editors can log in to \\u003Cb\\u003Ecreate\\u003C/b\\u003E, \\u003Cb\\u003Emanage\\u003C/b\\u003E, and \\u003Cb\\u003Epublish\\u003C/b\\u003E \\u003Ci\\u003Epages\\u003C/i\\u003E and\\u0026nbsp;\\u003Ci\\u003Econtent\\u003C/i\\u003E with ease.\\u0022}},{\\u0022id\\u0022:\\u0022NLjjjH7gsv\\u0022,\\u0022type\\u0022:\\u0022image\\u0022,\\u0022data\\u0022:{\\u0022file\\u0022:{\\u0022url\\u0022:\\u0022https://cdn.aglty.io/agility-cms-docs/images/block-editor/Refresh - Home Dash-03012024140343.png\\u0022,\\u0022size\\u0022:{\\u0022height\\u0022:1055,\\u0022width\\u0022:1850,\\u0022type\\u0022:\\u0022png\\u0022}},\\u0022caption\\u0022:\\u0022\\u0022,\\u0022withBorder\\u0022:false,\\u0022stretched\\u0022:false,\\u0022withBackground\\u0022:false}},{\\u0022id\\u0022:\\u00229pIk9R7-yR\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022The way you configure your instance is up to you. An instance can represent a single website or app, or you could take a\\u0026nbsp;\\u003Ca href=\\\\\\u0022https://help.agilitycms.com/hc/en-us/articles/360047762692\\\\\\u0022\\u003Emulti-tenanted approach\\u003C/a\\u003E\\u0026nbsp;where you are powering content for multiple websites. You can have access to many different instances, either grouped in your own\\u0026nbsp;\\u003Ca href=\\\\\\u0022https://help.agilitycms.com/hc/en-us/articles/360050974332\\\\\\u0022\\u003Eorganization\\u003C/a\\u003E\\u0026nbsp;or across different\\u0026nbsp;\\u003Ca href=\\\\\\u0022https://help.agilitycms.com/hc/en-us/articles/360050974332\\\\\\u0022\\u003Eorganizations\\u003C/a\\u003E.\\u0022}},{\\u0022id\\u0022:\\u0022jhiYnlD8_6\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022An instance has a corresponding\\u0026nbsp;\\u003Ca href=\\\\\\u0022https://agilitycms.com/pricing\\\\\\u0022\\u003Eplan/subscription\\u003C/a\\u003E\\u0026nbsp;which dictates certain limits and features.\\u0022}},{\\u0022id\\u0022:\\u0022nHgqxYRl7u\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022ordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022\\u003Cb\\u003EUnlimited flexibility\\u003C/b\\u003E - You can customize your content and its structure so it fits your exact use case\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022\\u003Cb\\u003EGrows with you\\u003C/b\\u003E - You can start from a Free plan, monitor your usage, and upgrade as you need to, instantly with our self-service plan management\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022\\u003Cb\\u003EStay in control\\u003C/b\\u003E - You control which users get access to each instance, content workflows, and if they have permissions to create, modify, and publish content\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022\\u003Cb\\u003EGet support\\u003C/b\\u003E - Use our community support or upgrade to a Pro plan for dedicated email support and SLAs\\u0022,\\u0022items\\u0022:[]}]}},{\\u0022id\\u0022:\\u0022toXFisnQU7\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Monitor your Usage\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u00229b9ap-N_wU\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Easily monitor your usage and know when you\\u0027re hitting your limits.\\u0026nbsp;Compare our plans\\u0026nbsp;today to see where you fit in.\\u0022}},{\\u0022id\\u0022:\\u0022muQENvSKup\\u0022,\\u0022type\\u0022:\\u0022image\\u0022,\\u0022data\\u0022:{\\u0022file\\u0022:{\\u0022url\\u0022:\\u0022https://cdn.aglty.io/agility-cms-docs/images/block-editor/Screenshot 2023-08-01 at 3.07.34 PM-08012023180751.png\\u0022,\\u0022size\\u0022:{\\u0022height\\u0022:604,\\u0022width\\u0022:1110,\\u0022type\\u0022:\\u0022png\\u0022}},\\u0022caption\\u0022:\\u0022\\u0022,\\u0022withBorder\\u0022:false,\\u0022stretched\\u0022:false,\\u0022withBackground\\u0022:false}},{\\u0022id\\u0022:\\u0022y58lRx5Q9E\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Upgrading your Plan\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022i7aWSWLXdu\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022You can upgrade your Agility instance at any time. Consider changing your plan if you require more users, dedicated support, or more bandwidth. \\u003Ca href=\\\\\\u0022mailto:support@agilitycms.com\\\\\\u0022\\u003EContact your Customer Success Manager\\u003C/a\\u003E to upgrade.\\u0022}},{\\u0022id\\u0022:\\u00222oY47Zjvhh\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Deleting Your Instance\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u00220DrWQGq8kr\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022It is possible to delete an Agility instance you may no longer need. To do so,\\u0026nbsp;Log in to Agility and select your Organization.\\u0022}},{\\u0022id\\u0022:\\u0022U9fLoX4csR\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022From the list of Instances in your Organization, click on the menu icon beside the instance you wish to delete to reveal the option for deletion.\\u0022}},{\\u0022id\\u0022:\\u0022O5lmn-5tbR\\u0022,\\u0022type\\u0022:\\u0022image\\u0022,\\u0022data\\u0022:{\\u0022file\\u0022:{\\u0022url\\u0022:\\u0022https://cdn.aglty.io/agility-cms-docs/images/block-editor/Screenshot 2023-08-01 at 3.08.34 PM-08012023180850.png\\u0022,\\u0022size\\u0022:{\\u0022height\\u0022:698,\\u0022width\\u0022:1190,\\u0022type\\u0022:\\u0022png\\u0022}},\\u0022caption\\u0022:\\u0022\\u0022,\\u0022withBorder\\u0022:false,\\u0022stretched\\u0022:false,\\u0022withBackground\\u0022:false}},{\\u0022id\\u0022:\\u0022aKkycaBmHn\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022When you click the \\u003Cb\\u003EDelete \\u003C/b\\u003Ebutton on an Instance, a prompt will open up stating what will happen upon deletion, and asks you to confirm before moving forward.\\u003Cbr\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022JiSmk-BBon\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Once you enter the name of the instance to confirm, and click \\\\\\u0022Delete Instance\\\\\\u0022, the instance will be removed from your organization.\\u0022}},{\\u0022id\\u0022:\\u0022L19IZrJX2B\\u0022,\\u0022type\\u0022:\\u0022warning\\u0022,\\u0022data\\u0022:{\\u0022title\\u0022:\\u0022How do I delete my Instance if I have a Paid Subscription?\\u0022,\\u0022message\\u0022:\\u0022If your Instance is on a\\u0026nbsp;Paid Subscription you\\u0027ll receive a different prompt requesting for you to reach out to support. If you receive this, contact\\u0026nbsp;support@agilitycms.com\\u0026nbsp;to cancel your subscription and delete your instance.\\u0022}}]}","classicContent":"{\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u0022QPuoBgcG7R\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022An instance represents a dedicated area for your editors to \\u003Cb\\u003Elog in\\u003C/b\\u003E, \\u003Cb\\u003Ecreate\\u003C/b\\u003E, \\u003Cb\\u003Emanage\\u003C/b\\u003E, and \\u003Cb\\u003Epublish\\u003C/b\\u003E\\u0026nbsp;\\u003Ci\\u003Epages\\u003C/i\\u003E and\\u0026nbsp;\\u003Ci\\u003Econtent\\u003C/i\\u003E with ease.\\u0022}},{\\u0022id\\u0