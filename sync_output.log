  additionalData: '{"LanguageCode":"en-us","Items":[{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"changelog_changelog245","definitionName":"ChangeLog","itemOrder":1},"fields":{"title":"Bug Fixes","description":"Fixed an issue where the API key value did not copy correctly from the Settings / API Keys page.  Fixed an issue where the Linked Content Dropdown did not show the selected value properly.","tags_TextField":"Bugs","tags_ValueField":"732"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"developerarticles","definitionName":"DocArticle","itemOrder":53},"fields":{"title":"CLI - Push / Pull / Clone","slug":"cli","description":"The Agility CLI allows you to pull, push, or clone an instance from your console.","content":"{\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u00227JCUB6W2kr\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022The Agility CLI (Command Line Interface) is an \\u003Ca href=\\\\\\u0022https://www.npmjs.com/package/@agility/cli\\\\\\u0022\\u003ENPM package\\u003C/a\\u003E that allows you to pull, push, or clone an instance from your console.\\u0026nbsp;\\u0022}},{\\u0022id\\u0022:\\u0022QkxY58aGC8\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022About the Agility CLI\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022KID269aepc\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022unordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022Provides features to perform operations to login to agility instance, pull the instance, push the instance and clone the instance (coupling of push and pull operations).\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Provides logs on failed records for content and pages.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Ability to generate Content and Pages in bulk for a Website.\\u0022,\\u0022items\\u0022:[]}]}},{\\u0022id\\u0022:\\u0022OMSNeRDdUN\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Please note that the Agility CLI is currently in beta with frequent updates.  Please use our Github issue tracker to provide feedback: \\u003Ca href=\\\\\\u0022https://github.com/agility/agility-cli/issues\\\\\\u0022\\u003Ehttps://github.com/agility/agility-cli/issues\\u003C/a\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022q7b8r4Btjq\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Getting Started\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u00224NkDdWbf6s\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Installation\\u0022,\\u0022level\\u0022:3}},{\\u0022id\\u0022:\\u0022fKjPVflLzh\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Using npm\\u0022,\\u0022level\\u0022:4}},{\\u0022id\\u0022:\\u0022cabpljThtf\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022unordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022To install the CLI locally using NPM, open the terminal and type:\\u0026nbsp;\\u003Ccode\\u003Enpm i @agility/cli\\u003C/code\\u003E.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022For global installation using NPM, open the terminal and type:\\u0026nbsp;\\u003Ccode\\u003Enpm i @agility/cli -g\\u003C/code\\u003E\\\\n\\u0022,\\u0022items\\u0022:[]}]}},{\\u0022id\\u0022:\\u0022JupMHeVhu9\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Using yarn\\u0022,\\u0022level\\u0022:4}},{\\u0022id\\u0022:\\u0022iI3imzrYQV\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022unordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022To install the CLI locally using yarn, open the terminal and type:\\u0026nbsp;\\u003Ccode\\u003Eyarn add @agility/cli\\u003C/code\\u003E.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022For global installation using yarn, open the terminal, and type:\\u0026nbsp;\\u003Ccode\\u003Eyarn global add @agility/cli\\u003C/code\\u003E.\\\\n\\\\n\\u0022,\\u0022items\\u0022:[]}]}},{\\u0022id\\u0022:\\u00220dy_cC32I1\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Using the CLI\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022T4bjWK_q-e\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Athenticate first\\u0022,\\u0022level\\u0022:3}},{\\u0022id\\u0022:\\u0022Vw0_ogrxXh\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022unordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022Login to your agility instance using the command\\u0026nbsp;\\u003Ccode\\u003Eagility login\\u003C/code\\u003E.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022A browser window will appear to perform the authentication process. You may have to authorize before proceeding.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Once authenticated use the following steps to perform operations on your instance.\\\\n\\\\n\\u0022,\\u0022items\\u0022:[]}]}},{\\u0022id\\u0022:\\u002203dKtAweHH\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Performing operations on CLI\\u0022,\\u0022level\\u0022:3}},{\\u0022id\\u0022:\\u0022CGWZOLC19E\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022unordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022To pull an instance use the command\\u0026nbsp;\\u003Ccode\\u003Eagility pull --guid=\\\\\\u0022\\u0026lt;\\u0026lt;Provide Guid of your Instance\\u0026gt;\\u0026gt;\\\\\\u0022 --locale=\\\\\\u0022\\u0026lt;\\u0026lt;Provide the locale of the Instance\\u0026gt;\\u0026gt;\\\\\\u0022 --channel=\\\\\\u0022\\u0026lt;\\u0026lt;Provide the sitemap to be pulled\\u0026gt;\\u0026gt;\\\\\\u0022\\u003C/code\\u003E\\u0026nbsp;to pull an instance.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022To push an instance use the command\\u0026nbsp;\\u003Ccode\\u003Eagility push --guid=\\\\\\u0022\\u0026lt;\\u0026lt;Provide the target Instance guid\\u0026gt;\\u0026gt; --locale=\\\\\\u0022\\u0026lt;\\u0026lt;Provide the locale of the Instance\\u0026gt;\\u0026gt;\\\\\\u0022\\u003C/code\\u003E\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022\\u003Ccode\\u003E\\u003C/code\\u003EFor instance cloning, this command is a mix of push and pull. Use the command\\u0026nbsp;\\u003Ccode\\u003Eagility clone --sourceGuid=\\\\\\u0022\\u0026lt;\\u0026lt;Provide Guid of your source Instance\\u0026gt;\\u0026gt;\\\\\\u0022 --targetGuid=\\\\\\u0022\\u0026lt;\\u0026lt;Provide the target Instance guid\\u0026gt;\\u0026gt;\\\\\\u0022 --locale=\\\\\\u0022\\u0026lt;\\u0026lt;Provide the locale of the Instance\\u0026gt;\\u0026gt;\\\\\\u0022 --channel=\\\\\\u0022\\u0026lt;\\u0026lt;Provide the sitemap to be cloned\\u0026gt;\\u0026gt;\\\\\\u0022\\u003C/code\\u003E\\u0026nbsp;to perform cloning between instances.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022To access the error logs, navigate to .agility-files/logs/instancelog.txt\\\\n\\\\n\\u0022,\\u0022items\\u0022:[]}]}},{\\u0022id\\u0022:\\u0022XZgt3Jbu2G\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Folder Structure\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u00221owJ37Mj-9\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022unordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022If a pull or clone instance is initiated, a local folder .agility-files is created.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Assets are saved inside the assets folder which consists of a json folder which has the metadata of the assets downloaded. The folder structure is .agility-files/assets/json for metadata. Rest assets are present inside the assets folder.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Galleries are saved inside the .agility-files/assets/galleries in a json format which is the metadata of the galleries of your source instance.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Containers metadata is present inside .agility-files/containers folder.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022For example, if the locale is en-us, then the Pages and Content metadata is present inside the folder .agility-files/en-us/item for Content and .agility-files/en-us/pages. These are the base folders to create Content and Pages to perform CLI push/clone. There are other folders created i.e. list, nestedsitemap, page, sitemap, state and urlredirections, which are not used by the CLI but are part of pull operation.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Models metadata is present inside .agility-files/models folder.\\u0022,\\u0022items\\u0022:[]},{\\u0022content\\u0022:\\u0022Pages metadata is present inside .agility-files/templates folder.\\u0022,\\u0022items\\u0022:[]}]}}]}","section_TextField":"APIs","section_ValueField":"255","concept_TextField":"API","concept_ValueField":"258"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"doccategories","definitionName":"DocCategory","itemOrder":11},"fields":{"title":"Apps","subTitle":"Learn how Apps work in Agility","icon":"LibraryIcon"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"apps_sidebarnav","definitionName":"SidebarNav","itemOrder":0},"fields":{"category_TextField":"Apps","category_ValueField":"853"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"si'... 289083 more characters,
