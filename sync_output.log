  additionalData: '{"LanguageCode":"en-us","Items":[{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"developersections","definitionName":"DocSection","itemOrder":0},"fields":{"title":"Introduction"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"changelog_changelogadde2186","definitionName":"ChangeLog","itemOrder":8},"fields":{"title":"Zip File Improvements","description":"When working with zip files in the Assets section, you will now see a preview for images inside the zip file before you upload them.","tags_TextField":"Improvement","tags_ValueField":"734"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"changelog_changelogadde2186","definitionName":"ChangeLog","itemOrder":9},"fields":{"title":"Version Compare Improvements","description":"We\\u0027ve updated the version compare functionality to work better with custom fields, especially those that save JSON data.","tags_TextField":"Improvement","tags_ValueField":"734"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"changelog_changelogadde2186","definitionName":"ChangeLog","itemOrder":10},"fields":{"title":"Workflow Actions Updates","description":"We\\u0027ve improved how the workflow actions function across the system.  Of note, if you have items in a list selected, the primary Publish/Unpublish actions at the top of the list will now work only on those selected items.  If you have no items selected, they will operation on the whole list.  We also brought back the \\u0022Stage\\u0022 action on Unpublished layouts and items.","tags_TextField":"Improvement","tags_ValueField":"734"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"astrosections","definitionName":"DocSection","itemOrder":0},"fields":{"title":"Introduction"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"astrosections","definitionName":"DocSection","itemOrder":1},"fields":{"title":"Starter"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"astrosections","definitionName":"DocSection","itemOrder":2},"fields":{"title":"Tutorials"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":null},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"astroarticles","definitionName":"DocArticle","itemOrder":0},"fields":{"title":"Astro and Agility CMS","slug":"astro-and-agility-cms","description":"Learn why Astro and Agility CMS work great together.","content":"{\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u0022J8MSTVcoUG\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022With Astro and Agility CMS, you can build a beautiful and performant website for your users, and deliver an amazing experience for both your \\u003Cb\\u003EEditors\\u003C/b\\u003E and \\u003Cb\\u003EDevelopers\\u003C/b\\u003E.\\u0022}},{\\u0022id\\u0022:\\u0022O_niWLKHvc\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Our Astro starter is built using server-side rendering, and will generate all your pages for you using the Layouts in the Sitemap. This allows developers to focus on building reusable UI Components and empowers editors to compose and manage all of the pages on their website.\\u0022}},{\\u0022id\\u0022:\\u00229c0oYqDuyE\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022A Great Editor Experience\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022osZUkwPYOZ\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022While using Agility CMS to power the content of your Astro site, editors can create and manage pages with ease. They\\u0027ll have a toolbox of UI Components (i.e. \\u003Cb\\u003EComponent Models\\u0026nbsp;\\u003C/b\\u003E\\u0026nbsp;and \\u003Cb\\u003ELayout Models\\u003C/b\\u003E) to select from that developers have built for them, and they\\u0027ll use these to compose their pages. Editors are able to preview content changes in real-time in a Preview Environment prior to publishing.\\u0022}},{\\u0022id\\u0022:\\u0022sR4Nd9VPSh\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022A Great Developer Experience\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022VEPbLnEzJJ\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Astro is a popular platform and framework for building content-driven websites. With a simple DX and fast development environment, the app will automatically reload if you change any of the source files. This will also load the latest (staging mode) content from Agility CMS. When you change the content in the CMS, simply reload your page to see those changes updated on the site. It\\u0027s extremely easy for developers to create reusable interactive UI Components that Editors can use to compose their pages.\\u0022}},{\\u0022id\\u0022:\\u0022-CrMb7VBjX\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Getting Started Quickly\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022UJOmChsfa0\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022The\\u0026nbsp;\\u003Ca href=\\\\\\u0022https://github.com/agility/agility-astro-starter\\\\\\u0022\\u003EAstro Starter\\u003C/a\\u003E\\u0026nbsp;template is a simple template that connects to a sample Agility CMS instance. This instance comes pre-configured with sample pages and content for a blog-styled website.\\u0026nbsp; You can use this as the starting point for fully featured site with YOUR content.\\u0022}}]}","section_TextField":"Introduction","section_ValueField":"1003","concept_TextField":"Overview","concept_ValueField":"47"},"seo":{"metaDescription":null,"metaKeywords":null,"metaHTML":null,"menuVisible":null,"sitemapVisible":false},"scripts":{"top":null,"bottom":null}},{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"astroarticles","definitionName":"DocArticle","itemOrder":1},"fields":{"title":"Using the Astro Starter","slug":"using-the-astro-starter","description":"Learn how to get started with Agility CMS and Astro.","content":"{\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u0022lSm5-_1ekr\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Astro paired with Agility CMS is a stack that delivers remarkable Developer Experience (DX), enables lightning-fast User Experiences (UX), and allows for best-in-class Editor Experience (EX). This article is aimed to help you get started with Astro and Agility CMS using a starter site.\\u0022}},{\\u0022id\\u0022:\\u00223oFyQEVD4-\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Develop Components, not Websites\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u00221T8vM3PC63\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022When building a site with Astro and Agility, we always recommend developers start by taking a look at our\\u0026nbsp;\\u003Ca href=\\\\\\u0022https://github.com/agility/agility-astro-starter\\\\\\u0022\\u003EAstro Starter\\u003C/a\\u003E, rather than starting from a blank slate.\\u0026nbsp;It showcases features such as our native\\u0026nbsp;\\u003Cb\\u003ELayout Management\\u003C/b\\u003E\\u0026nbsp;and shows\\u0026nbsp;how\\u0026nbsp;you should structure your Astro website. Our Astro and Agility starter serves as an example based on our recommended best-practices.\\u0022}},{\\u0022id\\u0022:\\u0022CHkoKXdCnC\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Editors have fine-grain control with the ability to manage all aspects of their\\u0026nbsp;page.\\u0026nbsp;They\\u0027re able to control what pages are on their website, and what is on each page. This means you can focus on building UI Components (i.e.\\u0026nbsp;\\u003Cb\\u003EPage\\u0026nbsp;Modules\\u003C/b\\u003E\\u0026nbsp;and\\u0026nbsp;\\u003Cb\\u003EPage Templates\\u003C/b\\u003E) that editors will use/reuse to compose their\\u0026nbsp;pages.\\u0022}},{\\u0022id\\u0022:\\u0022cRsM6NPnhs\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Set Up the Instance\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022-g0yUnBE8w\\u0022,\\u0022type\\u0022:\\u0022list\\u0022,\\u0022data\\u0022:{\\u0022style\\u0022:\\u0022unordered\\u0022,\\u0022items\\u0022:[{\\u0022content\\u0022:\\u0022Sign up for a free account and use the Next.js starter (it has a preconfigured models and cont'... 147927 more characters,
