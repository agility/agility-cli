  additionalData: '{"LanguageCode":"en-us","Items":[{"contentID":-1,"properties":{"state":null,"modifiedBy":null,"modified":null,"pullDate":null,"releaseDate":null,"versionID":null,"referenceName":"dotnetarticles","definitionName":"DocArticle","itemOrder":1},"fields":{"title":"Agility .NET 7 Updates","slug":"agility-net7-updates","content":"{\\u0022blocks\\u0022:[{\\u0022id\\u0022:\\u0022sqhT-os7D2\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022With .NET 7 we\\u0027ve introduced new typed endpoints for the following methods. The usage is the same as before, so any developers using the dotnet API will be familiar. The only difference is that now you can pass in a type to these generic methods that we will try to serialize for you. Of course if you so choose, you will still be able to use the older methods and handle deserialization yourselves.\\u0022}},{\\u0022id\\u0022:\\u0022SgdZu7IdfS\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Typed Endpoints\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022YnEJv8yxMH\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022\\u003Ccode class=\\\\\\u0022inline-code\\\\\\u0022\\u003Epublic async Task\\u0026lt;ContentItemResponse\\u0026lt;T\\u0026gt;\\u0026gt; GetTypedContentItem\\u0026lt;T\\u0026gt;(GetItemParameters getItemParameters)\\u003C/code\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022yUYEAvKCSa\\u0022,\\u0022type\\u0022:\\u0022code\\u0022,\\u0022data\\u0022:{\\u0022code\\u0022:\\u0022           var getParams = new GetItemParameters\\\\n            {\\\\n                ContentId = 111,\\\\n                Locale =\\\\\\u0022en-us\\\\\\u0022\\\\n            };\\\\n\\\\n            var featuredPostModel = await _fetchApiService.GetTypedContentItem\\u003CFeaturedPost_Model\\u003E(getParams);\\u0022}},{\\u0022id\\u0022:\\u00225cMvD9-uYJ\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022\\u003Ccode class=\\\\\\u0022inline-code\\\\\\u0022\\u003Epublic async Task\\u0026lt;ContentListResponse\\u0026lt;T\\u0026gt;\\u0026gt; GetTypedContentList\\u0026lt;T\\u0026gt;(GetListParameters getListParameters)\\u003C/code\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022a0RCI43JlL\\u0022,\\u0022type\\u0022:\\u0022code\\u0022,\\u0022data\\u0022:{\\u0022code\\u0022:\\u0022  var getParams = new GetListParameters\\\\n            {\\\\n                ReferenceName = \\\\\\u0022posts\\\\\\u0022,\\\\n                Locale = \\\\\\u0022en-us\\\\\\u0022\\\\n            };\\\\n            var posts = await _fetchApiService.GetTypedContentList\\u003CPost\\u003E(getParams);\\u0022}},{\\u0022id\\u0022:\\u0022MNiSCbq64u\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022\\u003Ccode class=\\\\\\u0022inline-code\\\\\\u0022\\u003Epublic async Task\\u0026lt;PageResponse\\u0026gt; GetTypedPage(GetPageParameters getPageParameters)\\u003C/code\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022FHu4McaPc7\\u0022,\\u0022type\\u0022:\\u0022code\\u0022,\\u0022data\\u0022:{\\u0022code\\u0022:\\u0022 var getPageExpandedParameters = new GetPageParameters()\\\\n            {\\\\n                PageId = 111,\\\\n                Locale = \\\\\\u0022en-us\\\\\\u0022,\\\\n                ExpandAllContentLinks = true,\\\\n                ContentLinkDepth = 2\\\\n            };\\\\n\\\\n            var page = await _fetchApiService.GetTypedPage(getPageExpandedParameters);\\u0022}},{\\u0022id\\u0022:\\u002288NMd8oxop\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022\\u003Ccode class=\\\\\\u0022inline-code\\\\\\u0022\\u003Epublic async Task\\u0026lt;List\\u0026lt;SitemapPage\\u0026gt;\\u0026gt; GetTypedSitemapFlat(GetSitemapParameters getSitemapParameters)\\u003C/code\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022MLVFs_IDfr\\u0022,\\u0022type\\u0022:\\u0022code\\u0022,\\u0022data\\u0022:{\\u0022code\\u0022:\\u0022  var getSitemapParameters = new GetSitemapParameters()\\\\n            {\\\\n                ChannelName = _appSettings.ChannelName,\\\\n                Locale = \\\\\\u0022en-us\\\\\\u0022\\\\n            };\\\\n\\\\n            var sitemap = await _fetchApiService.GetTypedSitemapFlat(getSitemapParameters);\\u0022}},{\\u0022id\\u0022:\\u0022M3gHWGZdrd\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022\\u003Ccode class=\\\\\\u0022inline-code\\\\\\u0022\\u003Epublic async Task\\u0026lt;List\\u0026lt;SitemapPage\\u0026gt;\\u0026gt; GetTypedSitemapNested(GetSitemapParameters getSitemapParameters)\\u003C/code\\u003E\\u0022}},{\\u0022id\\u0022:\\u0022Hsy1o1XKQo\\u0022,\\u0022type\\u0022:\\u0022code\\u0022,\\u0022data\\u0022:{\\u0022code\\u0022:\\u0022   var getSitemapParameters = new GetSitemapParameters()\\\\n            {\\\\n                ChannelName = \\\\\\u0022channel\\\\\\u0022,\\\\n                Locale = \\\\\\u0022en-us\\\\\\u0022\\\\n            };\\\\n\\\\n            var sitemap = await _fetchApiService.GetTypedSitemapNested(getSitemapParameters);\\u0022}},{\\u0022id\\u0022:\\u0022HVe3KDx_-E\\u0022,\\u0022type\\u0022:\\u0022header\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022GraphQL\\u0022,\\u0022level\\u0022:2}},{\\u0022id\\u0022:\\u0022YfQ4JP4ffm\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022In addition we\\u0027ve added a graphQL method as well:\\u0022}},{\\u0022id\\u0022:\\u0022GCdFTv7fe7\\u0022,\\u0022type\\u0022:\\u0022paragraph\\u0022,\\u0022data\\u0022:{\\u0022text\\u0022:\\u0022Pass in the\\u0026nbsp;\\u003Ccode\\u003EgraphQL query\\u003C/code\\u003E, the\\u0026nbsp;\\u003Ccode\\u003Elocale\\u003C/code\\u003E\\u0026nbsp;and the object\\u0026nbsp;\\u003Ccode\\u003Ename\\u003C/code\\u003E\\u003Ccode\\u003Epublic async Task\\u0026lt;List\\u0026lt;ContentItemResponse\\u0026lt;T\\u0026gt;\\u0026gt;\\u0026gt; GetContentBy